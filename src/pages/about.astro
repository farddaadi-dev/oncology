---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import aboutImage from "../assets/images/aboutHero.webp";
---

<BaseLayout
    title="درباره ما"
    description="آشنایی با پزشکان آنکولوژیست تهران، رزومه و دستاوردها"
    image="/default-og-image.jpg"
	>
    <Hero
        badge="درباره ما"
        titleLine1="همراهی علمی و انسانی"
        titleLine2="در مسیر درمان"
        description="ما با رویکردی علمی، فرد محور و مبتنی بر آخرین شواهد پزشکی، در کنار بیماران هستیم تا مسیر درمان با آرامش، دقت و همراهی بیشتری طی شود."
        image={aboutImage}
        alt="تصویر یک پزشک که در حال کمک به یک بیمار است"
    >

    </Hero>
    <section class="doctors-section">
        <div class="container">
            <div class="section-header">
                <span class="section-subtitle">آشنایی با پزشکان</span>
                <h2 class="section-title">همراهان شما در مسیر درمان</h2>
                <p class="section-description">ما باور داریم که درمان موثر تنها بر پایه دانش پزشکی نیست، بلکه نیازمند شناخت شرایط، اهداف و نیازهای هر بیمار است. با تکیه بر تجربه، شواهد علمی و ارتباط انسانی، در کنار بیماران و خانواده‌های آنان هستیم.</p>
            </div>
            <div class="doctors-grid">
                <!-- doctor 1 -->
                <article class="doctor-card">
                    <!-- doctor image -->
                    <img src="" alt="" class="doctor-image">
                    <div class="doctor-content">
                        <h3 class="doctor-name">دکتر نفیسه انصاری‌نژاد</h3>
                        <p class="doctor-specialty">فوق تخصص خون و آنکولوژی</p>
                        <p class="doctor-bio">ارائه خدمات تخصصی درمان سرطان و بیماریهای خونی با رویکردی مبتنی بر جدیدترین دستاوردهای علمی و توجه ویژه به کیفیت زندگی بیماران.</p>
                        <a href="" class="doctor-link">مشاهده رزومه</a>
                    </div>
                </article>
                <!-- doctor 2 -->
                <article class="doctor-card">
                    <!-- doctor image -->
                    <img src="" alt="" class="doctor-image">
                    <div class="doctor-content">
                        <h3 class="doctor-name">دکتر فرشید فرداد</h3>
                        <p class="doctor-specialty">فوق تخصص خون و آنکولوژی</p>
                        <p class="doctor-bio">بیش از دو دهه تجربه در تشخیص و درمان بیماری‌های خون وسرطان با تمرکز بر ارائه مراقبت علمی، فرد محور و مبتنی بر شواهد.</p>
                        <a href="" class="doctor-link">مشاهده رزومه</a>
                    </div>
                </article> 
            </div>
            <div class="philosophy-box">
                <h3 class="philosophy-title">رویکرد مشترک ما</h3>
                <div class="philosophy-grid">
                    <div class="philosophy-item">
                        <svg id="evidence" xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-book-open-check-icon lucide-book-open-check"><path d="M12 21V7"/><path d="m16 12 2 2 4-4"/><path d="M22 6V4a1 1 0 0 0-1-1h-5a4 4 0 0 0-4 4 4 4 0 0 0-4-4H3a1 1 0 0 0-1 1v13a1 1 0 0 0 1 1h6a3 3 0 0 1 3 3 3 3 0 0 1 3-3h6a1 1 0 0 0 1-1v-1.3"/></svg>
                        <span>درمان مبتنی بر شواهد</span>
                    </div>
                    <div class="philosophy-item">
                        <svg id="patient-center" xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-heart-handshake-icon lucide-heart-handshake"><path d="M19.414 14.414C21 12.828 22 11.5 22 9.5a5.5 5.5 0 0 0-9.591-3.676.6.6 0 0 1-.818.001A5.5 5.5 0 0 0 2 9.5c0 2.3 1.5 4 3 5.5l5.535 5.362a2 2 0 0 0 2.879.052 2.12 2.12 0 0 0-.004-3 2.124 2.124 0 1 0 3-3 2.124 2.124 0 0 0 3.004 0 2 2 0 0 0 0-2.828l-1.881-1.882a2.41 2.41 0 0 0-3.409 0l-1.71 1.71a2 2 0 0 1-2.828 0 2 2 0 0 1 0-2.828l2.823-2.762"/></svg>
                        <span>تصمیم‌گیری فرد محور</span>
                    </div>
                    <div class="philosophy-item">
                        <svg id="chat" xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-message-circle-more-icon lucide-message-circle-more"><path d="M2.992 16.342a2 2 0 0 1 .094 1.167l-1.065 3.29a1 1 0 0 0 1.236 1.168l3.413-.998a2 2 0 0 1 1.099.092 10 10 0 1 0-4.777-4.719"/><path d="M8 12h.01"/><path d="M12 12h.01"/><path d="M16 12h.01"/></svg>
                        <span>ارتباط شفاف با بیمار</span>
                    </div>
                    <div class="philosophy-item">
                        <svg id="leaf" xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-leafy-green-icon lucide-leafy-green"><path d="M2 22c1.25-.987 2.27-1.975 3.9-2.2a5.56 5.56 0 0 1 3.8 1.5 4 4 0 0 0 6.187-2.353 3.5 3.5 0 0 0 3.69-5.116A3.5 3.5 0 0 0 20.95 8 3.5 3.5 0 1 0 16 3.05a3.5 3.5 0 0 0-5.831 1.373 3.5 3.5 0 0 0-5.116 3.69 4 4 0 0 0-2.348 6.155C3.499 15.42 4.409 16.712 4.2 18.1 3.926 19.743 3.014 20.732 2 22"/><path d="M2 22 17 7"/></svg>
                        <span>توجه به کیفیت زندگی</span>
                    </div>
                </div>
            </div>
        </div>
    </section>
</BaseLayout>

<style>
    .doctors-section {
        padding: 7.5rem 0;
        background-color: var(--color-bg-primary);

    }
    .section-header {
        text-align: center;
        max-width: 850px;
        margin: 0 auto 5rem;
    }
    .section-subtitle {
        display: inline-block;
        color: var(--color-brand-accent-dark);
        font-size: var(--text-sm);
        font-weight: 500;
        margin-bottom: 1rem;
    }
    .section-title {
        font-size: var(--text-2xl);
        color: var(--color-text-primary);
        margin-bottom: 1.5rem;
    }
    .section-description {
        color: var(--color-text-secondary);
        line-height: 2;
        font-size: var(--text-md);
    }
    .doctors-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 2.5rem;
        margin-bottom: 5rem;
    }
    .doctor-card {
        background-color: white;
        border-radius: 28px;
        overflow: hidden;
        box-shadow: var(--shadow-medium);
        transition: 0.3s, ease;
    }
    .doctor-card:hover {
        transform: translateY(-8px);
    }
    .doctor-image {
        width: 100%;
        height: 420px;
        object-fit: cover;
    }
    .doctor-content {
        padding: 36px;
    }
    .doctor-name {
        font-size: var(--text-xl);
        color: var(--color-text-primary);
        margin-bottom: 10px;
    }
    .doctor-specialty {
        color: var(color-brand-accent);
        font-weight: 700;
        margin-bottom: 22px;
    }
    .doctor-bio {
        color: var(--color-text-secondary);
        line-height: 2;
        margin-bottom: 28px;
    }
    .doctor-link {
        color: var(--color-text-primary);
        font-weight: 700;
    }
    .doctor-link:hover {
        color: var(--color-brand-accent);
    }
    .philosophy-box {
        background-color: white;
        padding: 60px;
        border-radius: 32px;
        box-shadow: var(--shadow-soft);
    }
    .philosophy-title {
        text-align: center;
        margin-bottom: 2.5rem;
        font-size: var(--text-xl);
        color: var(--color-text-primary);
    }
    .phylosophy-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 24px;
    }
    .phylosophy-item .icon {
        display: block;
        font-size: 26px;
        color: var(--color-brand-accent);
        margin-bottom: 14px;
    }
</style>