---
import BaseLayout from "@/layouts/BaseLayout.astro";
import DoctorProfileHero from "@/components/doctors/DoctorProfileHero.astro";
import ProfessionalJourney from "@/components/doctors/ProfessionalJourney.astro";
import DoctorBiography from "@/components/doctors/DoctorBiography.astro";
import MembershipsCertifications from "@/components/doctors/MembershipsCertifications.astro";
import DoctorCTA from "@/components/doctors/DoctorCTA.astro";
import DoctorTreatmentApproach from "@/components/doctors/DoctorTreatmentApproach.astro"
import ResearchHighlights from "@/components/doctors/ResearchHighlights.astro";
import { doctors } from "@/data/doctors";
import Publications from "@/components/doctors/Publications.astro";

const doctor = doctors.find(
  item => item.id === "nafiseh"
)!;
---

<BaseLayout
  title={doctor.name}
  description="صفحه اختصاصی دکتر نفیسه انصاری‌نژاد"
  image="/default-og-image.jpg"
>

{doctor && (
    <>
      <DoctorProfileHero doctor={doctor} />
  
      {/* <DoctorIntroduction doctor={doctor} /> */}
  
      <DoctorBiography doctor={doctor} />

      <ProfessionalJourney doctorId={doctor.id} />

      <ResearchHighlights doctor={doctor}/>

      <DoctorTreatmentApproach doctor={doctor} />

      <Publications doctor={doctor} />
  
      <MembershipsCertifications doctor={doctor} />

      <DoctorCTA doctor={doctor} />
    </>
  )}


</BaseLayout>