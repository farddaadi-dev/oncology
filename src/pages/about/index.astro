---
import BaseLayout from '@/layouts/BaseLayout.astro'
import AboutHero from '@/components/about/AboutHero.astro'
import WhyChooseUs from "@/components/about/WhyChooseUs.astro";
import TreatmentPhilosophy from "@/components/about/TreatmentPhilosophy.astro";
import Section from '@/components/Section.astro'
import SectionHeading from '@/components/SectionHeading.astro'
import DoctorCard from '@/components/DoctorCard.astro'
import { doctors } from '@/data/doctors'
import AboutStory from '@/components/AboutStory.astro'
import WhatToExpect from '@/components/about/WhatToExpect.astro'
---
<BaseLayout
    title="درباره ما"
    description="آشنایی با پزشکان آنکولوژیست تهران، رزومه و دستاوردها"
    image="/default-og-image.jpg"
	>
    <AboutHero />
    
    <AboutStory />
    <TreatmentPhilosophy />
    <WhatToExpect />
    <Section>
        <SectionHeading 
            title="همراهان شما در مسیر درمان"
            subtitle="آشنایی با پزشکان"
            description="تیم پزشکی ما متشکل از دو فوق تخصص هماتولوژی و آنکولوژی است که با تکیه بر دانش روز، تجربه بالینی و رویکردی بیمار‌محور، خدمات تشخیصی و درمانی را ارائه می‌دهند. برای آشنایی بیشتر با سوابق علمی و حرفه‌ای هر پزشک، می‌توانید صفحه اختصاصی ایشان را مشاهده کنید."
        >

        </SectionHeading>
        <div class="doctors-grid" id="doctors-grid">

            {doctors.map((doctor) => (
        
                <DoctorCard
                    doctor={doctor}
                    buttonText="مشاهده رزومه"
                    buttonHref={doctor.profileUrl}
                />
        
            ))}
        
        </div>
    </Section>
    <WhyChooseUs />
    

</BaseLayout>

<style>
    .doctors-section {
        padding: 7.5rem 0;
        background-color: var(--color-bg-primary);

    }
    
    .doctors-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 2.5rem;
        margin-bottom: 5rem;
    }
    
    
    .icon {
        display: block;
        color: var(--color-brand-accent);
        margin: 0 auto 14px;
    }
  
</style>

<style is:global>
    @media (max-width: 992px) {
        #doctors-grid {
            grid-template-columns: 1fr;
        }
        .philosophy-box .philosophy-grid {
            grid-template-columns: repeat(2, 1fr);
        }
        .resume-button {
            display: flex;
            justify-content: center;
        }
    }

    @media (max-width: 768px) {
        #doctors-section {
            padding: 80px 0;
        }
        .section-header .section-title {
            font-size: var(--text-xl);
        }
        
        .doctor-card .doctor-content {
            padding: 28px;
        }
        .container .philosophy-box {
            padding: 36px 24px;
        }
        .philosophy-box .philosophy-grid {
            grid-template-columns: 1fr;
        }
    }
</style>