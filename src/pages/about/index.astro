---
import BaseLayout from '@/layouts/BaseLayout.astro'
import AboutHero from '@/components/about/AboutHero.astro'
import WhyChooseUs from "@/components/about/WhyChooseUs.astro";
import TreatmentPhilosophy from "@/components/about/TreatmentPhilosophy.astro";
import AboutStory from '@/components/AboutStory.astro'
import WhatToExpect from '@/components/about/WhatToExpect.astro'
import MeetTheDoctors from '@/components/about/MeetTheDoctors.astro';
import Cta from '@/components/Cta.astro';
import ButtonLink from '@/components/ButtonLink.astro';
---
<BaseLayout
    title="درباره ما"
    description="آشنایی با پزشکان آنکولوژیست تهران، رزومه و دستاوردها"
    image="/default-og-image.jpg"
	>
    <AboutHero />
    
    <AboutStory />
    <TreatmentPhilosophy />
    <WhatToExpect />
    <MeetTheDoctors />
    <WhyChooseUs />
    <Cta
  title="آماده گفت‌وگو درباره مسیر درمان خود هستید؟"
  description="تیم ما آماده است تا با بررسی شرایط شما، در انتخاب بهترین مسیر تشخیص، درمان یا دریافت نظر دوم همراهتان باشد. برای هماهنگی نوبت حضوری یا ثبت درخواست مشاوره آنلاین، از طریق گزینه‌های زیر اقدام کنید."
>

  <ButtonLink
    href="/visit"
    text="درخواست نوبت حضوری"
  />

  <ButtonLink
    href="/consultation"
    text="مشاوره آنلاین"
    variant="secondary"
  />

</Cta>
    

</BaseLayout>

<style>
    .doctors-section {
        padding: 7.5rem 0;
        background-color: var(--color-bg-primary);

    }
    
    .doctors-grid {

display: grid;

grid-template-columns:
  repeat(
    auto-fit,
    minmax(340px,1fr)
  );

gap: 3rem;

}
    
    
    .icon {
        display: block;
        color: var(--color-brand-accent);
        margin: 0 auto 14px;
    }
  
</style>

