---
import BaseLayout from '@/layouts/BaseLayout.astro'
import AboutHero from '@/components/about/AboutHero.astro'
import WhyChooseUs from "@/components/about/WhyChooseUs.astro";

import Section from '@/components/Section.astro'
import SectionHeading from '@/components/SectionHeading.astro'
import DoctorCard from '@/components/DoctorCard.astro'
import { doctors } from '@/data/doctors'
import AboutStory from '@/components/AboutStory.astro'
---
<BaseLayout
    title="درباره ما"
    description="آشنایی با پزشکان آنکولوژیست تهران، رزومه و دستاوردها"
    image="/default-og-image.jpg"
	>
    <AboutHero />
    <Section>
        <SectionHeading 
            title="همراهان شما در مسیر درمان"
            subtitle="آشنایی با پزشکان"
            description="تیم پزشکی ما متشکل از دو فوق تخصص هماتولوژی و آنکولوژی است که با تکیه بر دانش روز، تجربه بالینی و رویکردی بیمار‌محور، خدمات تشخیصی و درمانی را ارائه می‌دهند. برای آشنایی بیشتر با سوابق علمی و حرفه‌ای هر پزشک، می‌توانید صفحه اختصاصی ایشان را مشاهده کنید."
        >

        </SectionHeading>
        <div class="doctors-grid" id="doctors-grid">

            {doctors.map((doctor) => (
        
                <DoctorCard
                    doctor={doctor}
                    buttonText="مشاهده رزومه"
                    buttonHref={doctor.profileUrl}
                />
        
            ))}
        
        </div>
    </Section>
    <AboutStory />
    <WhyChooseUs />
    <section class="doctors-section" id="doctors-section">
        <div class="container">
            
            
            <div class="philosophy-box">
                <h3 class="philosophy-title">رویکرد مشترک ما</h3>
                <div class="philosophy-grid">
                    <div class="philosophy-item">
                        <svg class="icon" id="evidence" xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-book-open-check-icon lucide-book-open-check"><path d="M12 21V7"/><path d="m16 12 2 2 4-4"/><path d="M22 6V4a1 1 0 0 0-1-1h-5a4 4 0 0 0-4 4 4 4 0 0 0-4-4H3a1 1 0 0 0-1 1v13a1 1 0 0 0 1 1h6a3 3 0 0 1 3 3 3 3 0 0 1 3-3h6a1 1 0 0 0 1-1v-1.3"/></svg>
                        <span>درمان مبتنی بر شواهد</span>
                    </div>
                    <div class="philosophy-item">
                        <svg class="icon" id="patient-center" xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-heart-handshake-icon lucide-heart-handshake"><path d="M19.414 14.414C21 12.828 22 11.5 22 9.5a5.5 5.5 0 0 0-9.591-3.676.6.6 0 0 1-.818.001A5.5 5.5 0 0 0 2 9.5c0 2.3 1.5 4 3 5.5l5.535 5.362a2 2 0 0 0 2.879.052 2.12 2.12 0 0 0-.004-3 2.124 2.124 0 1 0 3-3 2.124 2.124 0 0 0 3.004 0 2 2 0 0 0 0-2.828l-1.881-1.882a2.41 2.41 0 0 0-3.409 0l-1.71 1.71a2 2 0 0 1-2.828 0 2 2 0 0 1 0-2.828l2.823-2.762"/></svg>
                        <span>تصمیم‌گیری بیمار محور</span>
                    </div>
                    <div class="philosophy-item">
                        <svg class="icon" id="chat" xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-message-circle-more-icon lucide-message-circle-more"><path d="M2.992 16.342a2 2 0 0 1 .094 1.167l-1.065 3.29a1 1 0 0 0 1.236 1.168l3.413-.998a2 2 0 0 1 1.099.092 10 10 0 1 0-4.777-4.719"/><path d="M8 12h.01"/><path d="M12 12h.01"/><path d="M16 12h.01"/></svg>
                        <span>ارتباط شفاف با بیمار</span>
                    </div>
                    <div class="philosophy-item">
                        <svg class="icon" id="leaf" xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-leafy-green-icon lucide-leafy-green"><path d="M2 22c1.25-.987 2.27-1.975 3.9-2.2a5.56 5.56 0 0 1 3.8 1.5 4 4 0 0 0 6.187-2.353 3.5 3.5 0 0 0 3.69-5.116A3.5 3.5 0 0 0 20.95 8 3.5 3.5 0 1 0 16 3.05a3.5 3.5 0 0 0-5.831 1.373 3.5 3.5 0 0 0-5.116 3.69 4 4 0 0 0-2.348 6.155C3.499 15.42 4.409 16.712 4.2 18.1 3.926 19.743 3.014 20.732 2 22"/><path d="M2 22 17 7"/></svg>
                        <span>توجه به کیفیت زندگی</span>
                    </div>
                </div>
            </div>
        </div>
    </section>
</BaseLayout>

<style>
    .doctors-section {
        padding: 7.5rem 0;
        background-color: var(--color-bg-primary);

    }
    
    .doctors-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 2.5rem;
        margin-bottom: 5rem;
    }
    
    .philosophy-box {
        background-color: white;
        padding: 60px;
        border-radius: 32px;
        box-shadow: var(--shadow-soft);
    }
    .philosophy-title {
        text-align: center;
        margin-bottom: 2.5rem;
        font-size: var(--text-xl);
        color: var(--color-text-primary);
    }
    .philosophy-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        justify-items: center;
        gap: 24px;
    }
    .icon {
        display: block;
        color: var(--color-brand-accent);
        margin: 0 auto 14px;
    }
  
</style>

<style is:global>
    @media (max-width: 992px) {
        #doctors-grid {
            grid-template-columns: 1fr;
        }
        .philosophy-box .philosophy-grid {
            grid-template-columns: repeat(2, 1fr);
        }
        .resume-button {
            display: flex;
            justify-content: center;
        }
    }

    @media (max-width: 768px) {
        #doctors-section {
            padding: 80px 0;
        }
        .section-header .section-title {
            font-size: var(--text-xl);
        }
        
        .doctor-card .doctor-content {
            padding: 28px;
        }
        .container .philosophy-box {
            padding: 36px 24px;
        }
        .philosophy-box .philosophy-grid {
            grid-template-columns: 1fr;
        }
    }
</style>