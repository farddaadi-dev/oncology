---
import ServiceDetailLayout from "@/layouts/ServiceDetailLayout.astro";

import Section from "@/components/Section.astro";
import SectionHeading from "@/components/SectionHeading.astro";

import FeatureGrid from "@/components/FeatureGrid.astro";
import FeatureCard from "@/components/FeatureCard.astro";

import Faq from "@/components/Faq.astro";

import { getService } from "@/lib/getService";
import { hematologyFAQ } from "@/data/hematologyFAQ";

const service = getService("hematology");
---

<ServiceDetailLayout service={service}>

  <!-- content goes here -->
  <Section>

    <SectionHeading
        title="بیماری‌های خونی چیست؟"
        subtitle="تشخیص دقیق و درمان تخصصی اختلالات خون و مغز استخوان"
    />

    <p>
        بیماری‌های خونی طیف گسترده‌ای از اختلالات را شامل می‌شوند که ممکن است گلبول‌های قرمز، گلبول‌های سفید، پلاکت‌ها، سیستم انعقادی یا مغز استخوان را درگیر کنند. این بیماری‌ها می‌توانند مادرزادی یا اکتسابی بوده و از مشکلات شایع مانند کم‌خونی تا بیماری‌های پیچیده‌تر هماتولوژیک را در بر گیرند.
    </p>

    <p>
        تشخیص صحیح، بررسی علت زمینه‌ای و انتخاب درمان مناسب نقش مهمی در کنترل بیماری، پیشگیری از عوارض و بهبود کیفیت زندگی بیماران دارد.
    </p>

</Section>

<Section background="secondary">

    <SectionHeading
      title="بیماری‌های تحت ارزیابی و درمان"
      subtitle="خدمات تخصصی در حوزه هماتولوژی"
    />
  
    <FeatureGrid>
  
      <FeatureCard
        title="کم‌خونی"
        description="تشخیص علت انواع کم‌خونی و انتخاب درمان مناسب بر اساس شرایط هر بیمار."
        icon="heartPulse"
      />
  
      <FeatureCard
        title="اختلالات انعقادی"
        description="بررسی خونریزی‌های غیرطبیعی، اختلالات انعقاد و مشکلات مرتبط با لخته شدن خون."
        icon="shield"
      />
  
      <FeatureCard
        title="اختلالات سلول‌های خونی"
        description="ارزیابی افزایش یا کاهش گلبول‌های سفید، گلبول‌های قرمز و پلاکت‌ها."
        icon="activity"
      />
  
      <FeatureCard
        title="بیماری‌های مغز استخوان"
        description="بررسی تخصصی بیماری‌های مرتبط با مغز استخوان و اختلالات تولید سلول‌های خونی."
        icon="flaskConical"
      />
  
    </FeatureGrid>
  
  </Section>
  <Section>

    <SectionHeading
      title="کم‌خونی"
      subtitle="تشخیص علت زمینه‌ای و انتخاب درمان مناسب برای هر بیمار"
    />
  
    <p>
      کم‌خونی یکی از شایع‌ترین بیماری‌های خونی است و می‌تواند به دلایل مختلفی از جمله کمبود آهن، کمبود ویتامین‌ها، بیماری‌های مزمن، اختلالات مغز استخوان یا سایر بیماری‌های زمینه‌ای ایجاد شود. تشخیص صحیح علت کم‌خونی، نخستین و مهم‌ترین گام در انتخاب درمان مؤثر است.
    </p>
  
    <p>
      پس از ارزیابی بالینی و بررسی آزمایش‌های لازم، برنامه درمانی متناسب با علت زمینه‌ای طراحی می‌شود. هدف درمان، علاوه بر اصلاح کم‌خونی، برطرف کردن علت اصلی بیماری و پیشگیری از عود آن است.
    </p>
  
    <FeatureGrid>
  
      <FeatureCard
        title="تشخیص علت کم‌خونی"
        description="بررسی دقیق علائم، سابقه پزشکی و عوامل زمینه‌ای برای شناسایی علت اصلی کم‌خونی."
        icon="clipboardList"
      />
  
      <FeatureCard
        title="بررسی‌های آزمایشگاهی"
        description="استفاده از آزمایش‌های تخصصی خون و در صورت نیاز بررسی‌های تکمیلی برای رسیدن به تشخیص دقیق."
        icon="flaskConical"
      />
  
      <FeatureCard
        title="درمان متناسب با علت"
        description="انتخاب درمان بر اساس نوع کم‌خونی که ممکن است شامل اصلاح کمبودها، درمان بیماری زمینه‌ای یا سایر اقدامات تخصصی باشد."
        icon="heartHandshake"
      />
  
      <FeatureCard
        title="پیگیری روند درمان"
        description="ارزیابی منظم پاسخ به درمان و تنظیم برنامه درمانی بر اساس وضعیت بیمار."
        icon="activity"
      />
  
    </FeatureGrid>
  
  </Section>
  <Section background="secondary">

    <SectionHeading
      title="اختلالات انعقادی"
      subtitle="ارزیابی تخصصی مشکلات خونریزی و لخته شدن خون"
    />
  
    <p>
      اختلالات انعقادی می‌توانند به صورت خونریزی‌های غیرطبیعی، کبودی‌های مکرر یا افزایش خطر تشکیل لخته‌های خونی بروز کنند. این اختلالات ممکن است ارثی یا اکتسابی باشند و تشخیص صحیح آن‌ها نقش مهمی در انتخاب درمان مناسب دارد.
    </p>
  
    <p>
      بررسی شرح حال، معاینه بالینی و انجام آزمایش‌های تخصصی انعقادی به شناسایی علت بیماری کمک می‌کند تا مناسب‌ترین برنامه درمانی برای هر بیمار طراحی شود.
    </p>
  
    <FeatureGrid>
  
      <FeatureCard
        title="ارزیابی علائم"
        description="بررسی خونریزی‌های غیرطبیعی، کبودی، سابقه خانوادگی و سایر عوامل مؤثر در تشخیص بیماری."
        icon="clipboardList"
      />
  
      <FeatureCard
        title="آزمایش‌های انعقادی"
        description="انجام آزمایش‌های تخصصی برای ارزیابی عملکرد سیستم انعقاد و تشخیص دقیق اختلالات."
        icon="flaskConical"
      />
  
      <FeatureCard
        title="درمان فردمحور"
        description="انتخاب روش درمان بر اساس نوع اختلال، شدت بیماری و شرایط اختصاصی هر بیمار."
        icon="heartHandshake"
      />
  
      <FeatureCard
        title="پیشگیری از عوارض"
        description="پیگیری منظم و آموزش بیمار برای کاهش خطر خونریزی یا تشکیل لخته‌های ناخواسته."
        icon="shield"
      />
  
    </FeatureGrid>
  
  </Section>
  <Section>

    <SectionHeading
      title="سایر بیماری‌های هماتولوژیک"
      subtitle="ارزیابی تخصصی سایر اختلالات خون و مغز استخوان"
    />
  
    <p>
      علاوه بر کم‌خونی و اختلالات انعقادی، طیف وسیعی از بیماری‌های هماتولوژیک می‌توانند بر گلبول‌های سفید، پلاکت‌ها، مغز استخوان و سایر اجزای خون تأثیر بگذارند. تشخیص دقیق این بیماری‌ها نیازمند بررسی بالینی، آزمایش‌های تخصصی و در برخی موارد اقدامات تشخیصی تکمیلی است.
    </p>
  
    <p>
      هدف از ارزیابی تخصصی، شناسایی علت بیماری، تعیین شدت آن و انتخاب مناسب‌ترین برنامه درمانی یا پیگیری بر اساس شرایط اختصاصی هر بیمار است.
    </p>
  
    <FeatureGrid>
  
      <FeatureCard
        title="اختلالات گلبول‌های سفید"
        description="بررسی کاهش یا افزایش غیرطبیعی گلبول‌های سفید و علل زمینه‌ای آن."
        icon="activity"
      />
  
      <FeatureCard
        title="اختلالات پلاکت"
        description="ارزیابی کاهش یا افزایش پلاکت و بیماری‌های مرتبط با عملکرد پلاکت‌ها."
        icon="shield"
      />
  
      <FeatureCard
        title="بیماری‌های مغز استخوان"
        description="بررسی بیماری‌های مرتبط با تولید سلول‌های خونی و اختلالات مغز استخوان."
        icon="flaskConical"
      />
  
      <FeatureCard
        title="پیگیری تخصصی"
        description="ارزیابی منظم وضعیت بیمار و تنظیم برنامه تشخیصی یا درمانی بر اساس روند بیماری."
        icon="clipboardList"
      />
  
    </FeatureGrid>
  
  </Section>
  <Section background="secondary">

    <SectionHeading
      title="پیگیری و ارزیابی بیماران"
      subtitle="همراهی مستمر در تشخیص، درمان و پایش بیماری‌های خونی"
    />
  
    <p>
      مراقبت از بیماران مبتلا به بیماری‌های خونی تنها به تشخیص اولیه محدود نمی‌شود. پیگیری منظم وضعیت بیمار، ارزیابی نتایج آزمایش‌ها، بررسی پاسخ به درمان و تشخیص به‌موقع تغییرات احتمالی، بخش مهمی از فرآیند مراقبت تخصصی است.
    </p>
  
    <p>
      بر اساس روند بیماری و شرایط هر بیمار، برنامه پیگیری به‌صورت اختصاصی تنظیم می‌شود تا علاوه بر کنترل بیماری، از بروز عوارض احتمالی پیشگیری شده و بهترین کیفیت زندگی برای بیمار حفظ شود.
    </p>
  
    <FeatureGrid>
  
      <FeatureCard
        title="پایش آزمایش‌ها"
        description="بررسی منظم نتایج آزمایش‌های خون برای ارزیابی روند بیماری و پاسخ به درمان."
        icon="activity"
      />
  
      <FeatureCard
        title="ارزیابی بالینی"
        description="معاینه و بررسی علائم بیمار برای تصمیم‌گیری درباره ادامه یا تغییر برنامه درمانی."
        icon="stethoscope"
      />
  
      <FeatureCard
        title="تنظیم برنامه درمان"
        description="اصلاح برنامه درمان یا پیگیری بر اساس نتایج ارزیابی‌های دوره‌ای و شرایط بیمار."
        icon="clipboardList"
      />
  
      <FeatureCard
        title="مراقبت بلندمدت"
        description="همراهی مستمر برای پیشگیری از عوارض، کنترل بیماری و حفظ کیفیت زندگی بیمار."
        icon="heartHandshake"
      />
  
    </FeatureGrid>
  
  </Section>

  <Section>

    <SectionHeading
      title="سؤالات متداول"
    />
  
    <Faq items={hematologyFAQ} />
  
  </Section>

</ServiceDetailLayout>