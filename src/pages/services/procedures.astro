---
import ServiceDetailLayout from "@/layouts/ServiceDetailLayout.astro";
import Section from "@/components/Section.astro";
import SectionHeading from "@/components/SectionHeading.astro";
import FeatureGrid from "@/components/FeatureGrid.astro";
import FeatureCard from "@/components/FeatureCard.astro";
import { getService } from "@/lib/getService";
import Faq from "@/components/Faq.astro";
import { proceduresFAQ } from "@/data/proceduresFAQ";

const service = getService("procedures");
---

<ServiceDetailLayout service={service}>

  <Section>

    <SectionHeading
      title="اقدامات تخصصی در هماتولوژی و انکولوژی"
      subtitle="روش‌های تشخیصی و درمانی برای بررسی دقیق‌تر بیماری"
    />

    <p>
      در برخی بیماران، برای تشخیص دقیق‌تر یا انجام درمان‌های تخصصی، ممکن است انجام اقدامات تکمیلی ضروری باشد. این اقدامات با هدف بررسی سلول‌های خونی، ارزیابی وضعیت مغز استخوان یا رساندن درمان به محل مورد نظر انجام می‌شوند.
    </p>

    <p>
      انتخاب نوع اقدام بر اساس شرایط بیمار، نوع بیماری، نتایج آزمایش‌ها و نظر پزشک متخصص انجام می‌شود.
    </p>

  </Section>
  <Section background="secondary">

    <SectionHeading
      title="چه اقداماتی انجام می‌شود؟"
      subtitle="اقدامات تخصصی تشخیصی و درمانی در حوزه هماتولوژی و انکولوژی"
    />
  
    <FeatureGrid>
  
      <FeatureCard
        title="آسپیراسیون مغز استخوان"
        description="نمونه‌گیری از سلول‌های مغز استخوان برای بررسی دقیق تولید سلول‌های خونی و کمک به تشخیص بیماری‌های مختلف."
        icon="activity"
      />
  
      <FeatureCard
        title="بیوپسی مغز استخوان"
        description="برداشت نمونه کوچک از بافت مغز استخوان برای ارزیابی ساختار آن و بررسی اختلالات مرتبط با تولید سلول‌های خونی."
        icon="flaskConical"
      />
  
      <FeatureCard
        title="پونکسیون کمری (LP)"
        description="نمونه‌گیری از مایع مغزی نخاعی برای بررسی برخی بیماری‌ها یا کمک به تصمیم‌گیری درمانی در شرایط خاص."
        icon="stethoscope"
      />
  
      <FeatureCard
        title="شیمی‌درمانی داخل نخاعی"
        description="تزریق داروهای درمانی به فضای اطراف نخاع در شرایطی که نیاز به رساندن مستقیم درمان به سیستم عصبی مرکزی وجود دارد."
        icon="pill"
      />
  
    </FeatureGrid>
  
  </Section>
  <Section>

    <SectionHeading
      title="آسپیراسیون و بیوپسی مغز استخوان"
      subtitle="بررسی دقیق سلول‌ها و ساختار مغز استخوان برای تشخیص بیماری‌های خونی"
    />
  
    <p>
      مغز استخوان محل تولید سلول‌های خونی شامل گلبول‌های قرمز، گلبول‌های سفید و پلاکت‌ها است. در برخی شرایط، برای بررسی علت تغییرات غیرطبیعی در آزمایش خون یا ارزیابی برخی بیماری‌های خونی، بررسی مستقیم مغز استخوان ضروری می‌شود.
    </p>
  
    <p>
      در آسپیراسیون مغز استخوان، نمونه‌ای از سلول‌های مغز استخوان برای بررسی زیر میکروسکوپ تهیه می‌شود. در بیوپسی مغز استخوان، نمونه کوچکی از بافت مغز استخوان برای ارزیابی ساختار و وضعیت تولید سلول‌ها برداشته می‌شود. ترکیب این دو روش می‌تواند اطلاعات ارزشمندی برای تشخیص و برنامه‌ریزی درمان فراهم کند.
    </p>
  
    <FeatureGrid>
  
      <FeatureCard
        title="چه زمانی انجام می‌شود؟"
        description="برای بررسی برخی کم‌خونی‌ها، اختلالات سلول‌های خونی، بیماری‌های مغز استخوان یا ارزیابی پاسخ به درمان."
        icon="clipboardList"
      />
  
      <FeatureCard
        title="نحوه انجام"
        description="این اقدام معمولاً به صورت سرپایی و با استفاده از بی‌حسی موضعی انجام می‌شود تا ناراحتی بیمار به حداقل برسد."
        icon="stethoscope"
      />
  
      <FeatureCard
        title="مدت زمان انجام"
        description="زمان انجام پروسیجر معمولاً کوتاه است و بیمار پس از مراقبت‌های اولیه می‌تواند به فعالیت‌های روزمره بازگردد."
        icon="calendarClock"
      />
  
      <FeatureCard
        title="بررسی نتایج"
        description="نمونه تهیه‌شده توسط متخصصان مربوطه بررسی می‌شود و نتایج در تصمیم‌گیری تشخیصی و درمانی مورد استفاده قرار می‌گیرد."
        icon="fileText"
      />
  
    </FeatureGrid>
  
  </Section>
  <Section background="secondary">

    <SectionHeading
      title="پونکسیون کمری (LP)"
      subtitle="بررسی مایع مغزی نخاعی برای کمک به تشخیص و درمان برخی بیماری‌ها"
    />
  
    <p>
      پونکسیون کمری یا Lumbar Puncture روشی تشخیصی است که در آن مقدار کمی از مایع مغزی نخاعی برای بررسی‌های تخصصی گرفته می‌شود. این مایع اطلاعات مهمی درباره برخی بیماری‌های مرتبط با سیستم عصبی مرکزی در اختیار پزشک قرار می‌دهد.
    </p>
  
    <p>
      در بیماران مبتلا به برخی بیماری‌های خونی یا سرطانی، ممکن است برای ارزیابی درگیری سیستم عصبی مرکزی، بررسی پاسخ به درمان یا کمک به تصمیم‌گیری درمانی انجام این اقدام ضروری باشد.
    </p>
  
    <FeatureGrid>
  
      <FeatureCard
        title="چه زمانی انجام می‌شود؟"
        description="بر اساس نوع بیماری، شرایط بیمار و نیاز به بررسی مایع مغزی نخاعی برای تشخیص یا برنامه‌ریزی درمان."
        icon="clipboardList"
      />
  
      <FeatureCard
        title="نحوه انجام"
        description="این اقدام معمولاً با بی‌حسی موضعی و رعایت اصول استریل انجام می‌شود تا ایمنی و راحتی بیمار حفظ شود."
        icon="shield"
      />
  
      <FeatureCard
        title="بررسی نمونه"
        description="نمونه تهیه‌شده برای بررسی‌های تخصصی آزمایشگاهی و کمک به تشخیص دقیق‌تر مورد ارزیابی قرار می‌گیرد."
        icon="flaskConical"
      />
  
      <FeatureCard
        title="مراقبت پس از انجام"
        description="رعایت توصیه‌های پزشک پس از انجام پروسیجر به کاهش عوارض احتمالی و بهبود روند بهبودی کمک می‌کند."
        icon="heartHandshake"
      />
  
    </FeatureGrid>
  
  </Section>
  <Section>

    <SectionHeading
      title="شیمی‌درمانی داخل نخاعی"
      subtitle="رساندن مستقیم دارو به فضای اطراف مغز و نخاع در شرایط خاص"
    />
  
    <p>
      شیمی‌درمانی داخل نخاعی (Intrathecal Chemotherapy) روشی است که در آن داروهای درمانی مستقیماً به مایع مغزی نخاعی تزریق می‌شوند. این روش در شرایطی استفاده می‌شود که نیاز به پیشگیری یا درمان درگیری سیستم عصبی مرکزی وجود داشته باشد.
    </p>
  
    <p>
      انتخاب این روش درمانی بر اساس نوع بیماری، میزان خطر درگیری سیستم عصبی مرکزی و شرایط اختصاصی هر بیمار انجام می‌شود و ممکن است به‌صورت مستقل یا همراه با سایر روش‌های درمانی مورد استفاده قرار گیرد.
    </p>
  
    <FeatureGrid>
  
      <FeatureCard
        title="چه زمانی استفاده می‌شود؟"
        description="در برخی بیماری‌های خونی و سرطان‌ها، برای پیشگیری یا درمان احتمال درگیری سیستم عصبی مرکزی."
        icon="clipboardList"
      />
  
      <FeatureCard
        title="نحوه انجام"
        description="دارو با روش استریل و معمولاً از طریق پونکسیون کمری به فضای مایع مغزی نخاعی تزریق می‌شود."
        icon="pill"
      />
  
      <FeatureCard
        title="برنامه درمانی"
        description="تعداد دفعات و نوع دارو بر اساس تشخیص، پروتکل درمانی و شرایط بیمار تعیین می‌شود."
        icon="calendarClock"
      />
  
      <FeatureCard
        title="پایش و مراقبت"
        description="وضعیت بیمار پس از انجام اقدام بررسی شده و مراقبت‌های لازم برای حفظ ایمنی درمان انجام می‌شود."
        icon="heartPulse"
      />
  
    </FeatureGrid>
  
  </Section>
  <Section background="secondary">

    <SectionHeading
      title="آمادگی قبل از انجام اقدامات تخصصی"
      subtitle="اطمینان از انجام ایمن و دقیق پروسیجرهای تشخیصی و درمانی"
    />
  
    <p>
      قبل از انجام هر اقدام تخصصی، وضعیت عمومی بیمار، سوابق پزشکی، داروهای مصرفی و نتایج بررسی‌های قبلی ارزیابی می‌شود. رعایت توصیه‌های پزشک به انجام ایمن‌تر پروسیجر و کاهش احتمال عوارض کمک می‌کند.
    </p>
  
    <FeatureGrid>
  
      <FeatureCard
        title="بررسی مدارک پزشکی"
        description="همراه داشتن آزمایش‌ها، تصاویر پزشکی، گزارش‌های پاتولوژی و سوابق درمانی به تصمیم‌گیری دقیق‌تر کمک می‌کند."
        icon="fileText"
      />
  
      <FeatureCard
        title="بررسی داروهای مصرفی"
        description="اطلاع پزشک از داروها، به‌خصوص داروهای مؤثر بر انعقاد خون، برای برنامه‌ریزی ایمن پروسیجر ضروری است."
        icon="clipboardList"
      />
  
      <FeatureCard
        title="ارزیابی پیش از اقدام"
        description="شرایط بیمار، نتایج آزمایش‌ها و نیاز به بررسی‌های تکمیلی پیش از انجام اقدام ارزیابی می‌شود."
        icon="stethoscope"
      />
  
      <FeatureCard
        title="دریافت توصیه‌های لازم"
        description="دستورالعمل‌های مربوط به روز انجام پروسیجر و مراقبت‌های بعد از آن به بیمار ارائه می‌شود."
        icon="check"
      />
  
    </FeatureGrid>
  
  </Section>
  <Section>

    <SectionHeading
      title="مراقبت پس از انجام اقدامات تخصصی"
      subtitle="پیگیری مناسب برای بهبود روند بهبودی و کاهش عوارض احتمالی"
    />
  
    <p>
      پس از انجام اقدامات تخصصی، وضعیت بیمار بر اساس نوع پروسیجر و شرایط فردی بررسی می‌شود. رعایت توصیه‌های پزشک و توجه به علائم احتمالی، نقش مهمی در مراقبت ایمن پس از انجام اقدام دارد.
    </p>
  
    <p>
      در صورت نیاز، برنامه پیگیری، بررسی نتایج و اقدامات بعدی توسط پزشک مشخص می‌شود تا روند تشخیص یا درمان با دقت ادامه پیدا کند.
    </p>
  
    <FeatureGrid>
  
      <FeatureCard
        title="استراحت و مراقبت اولیه"
        description="رعایت توصیه‌های مربوط به فعالیت‌های روزانه و مراقبت از محل انجام پروسیجر در صورت نیاز."
        icon="heart"
      />
  
      <FeatureCard
        title="توجه به علائم احتمالی"
        description="آگاهی از علائمی که نیاز به اطلاع‌رسانی به پزشک یا ارزیابی بیشتر دارند."
        icon="triangleAlert"
      />
  
      <FeatureCard
        title="بررسی نتایج"
        description="ارزیابی نتایج آزمایش‌ها و نمونه‌ها برای تصمیم‌گیری درباره ادامه مسیر تشخیص یا درمان."
        icon="fileText"
      />
  
      <FeatureCard
        title="پیگیری پزشکی"
        description="ادامه ارتباط با تیم درمان برای بررسی وضعیت بیمار و تنظیم اقدامات بعدی."
        icon="calendarClock"
      />
  
    </FeatureGrid>
  
  </Section>
  <Section background="secondary">

    <SectionHeading
      title="سؤالات متداول"
    />
  
    <Faq items={proceduresFAQ} />
  
  </Section>

</ServiceDetailLayout>