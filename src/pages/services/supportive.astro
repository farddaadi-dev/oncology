---
import ServiceDetailLayout from "@/layouts/ServiceDetailLayout.astro";
import Section from "@/components/Section.astro";
import SectionHeading from "@/components/SectionHeading.astro";
import FeatureGrid from "@/components/FeatureGrid.astro";
import FeatureCard from "@/components/FeatureCard.astro";
import { getService } from "@/lib/getService";
import Faq from "@/components/Faq.astro";
import { supportiveFAQ } from "@/data/supportiveFAQ";

const service = getService("supportive");
---

<ServiceDetailLayout service={service}>

  <Section>

    <SectionHeading
      title="مراقبت حمایتی در درمان سرطان چیست؟"
      subtitle="تمرکز بر کنترل علائم و حفظ کیفیت زندگی بیمار"
    />

    <p>
      مراقبت حمایتی بخشی جدایی‌ناپذیر از درمان جامع سرطان است و با هدف کاهش علائم ناشی از بیماری یا درمان‌ها، بهبود توانایی انجام فعالیت‌های روزمره و افزایش کیفیت زندگی بیمار ارائه می‌شود.
    </p>

    <p>
      این مراقبت‌ها می‌توانند همزمان با درمان‌های ضد سرطان مانند شیمی‌درمانی، ایمونوتراپی یا درمان‌های هدفمند ارائه شوند و به بیمار کمک کنند دوره درمان را با شرایط بهتر و عوارض قابل کنترل‌تر طی کند.
    </p>

  </Section>
  <Section background="secondary">

    <SectionHeading
      title="چه علائمی نیاز به مراقبت حمایتی دارند؟"
      subtitle="مدیریت علائم و عوارض برای تجربه بهتر دوره درمان"
    />
  
    <FeatureGrid>
  
      <FeatureCard
        title="کنترل دردهای سرطانی"
        description="ارزیابی و مدیریت علمی درد ناشی از بیماری یا درمان با هدف افزایش راحتی و توانایی انجام فعالیت‌های روزمره."
        icon="heartPulse"
      />
  
      <FeatureCard
        title="کنترل تهوع و عوارض درمان"
        description="پیشگیری و درمان تهوع، مشکلات گوارشی و سایر عوارض مرتبط با درمان‌های ضد سرطان."
        icon="activity"
      />
  
      <FeatureCard
        title="مدیریت ضعف و خستگی"
        description="بررسی عوامل مؤثر بر ضعف و خستگی و ارائه راهکارهای مناسب برای حفظ انرژی و عملکرد بیمار."
        icon="smile"
      />
  
      <FeatureCard
        title="بهبود اشتها و وضعیت تغذیه"
        description="کمک به مدیریت کاهش اشتها و حفظ وضعیت تغذیه‌ای مناسب در طول دوره درمان."
        icon="heart"
      />
  
    </FeatureGrid>
  
  </Section>
  <Section>

    <SectionHeading
      title="کنترل دردهای سرطانی"
      subtitle="ارزیابی دقیق و مدیریت فردمحور درد در طول مسیر درمان"
    />
  
    <p>
      درد در بیماران مبتلا به سرطان می‌تواند به دلایل مختلفی از جمله خود بیماری، درمان‌های ضد سرطان یا برخی اقدامات پزشکی ایجاد شود. ارزیابی دقیق نوع، شدت و علت درد، اولین قدم برای انتخاب بهترین روش کنترل آن است.
    </p>
  
    <p>
      هدف از کنترل درد، تنها کاهش شدت درد نیست؛ بلکه کمک به حفظ فعالیت‌های روزمره، خواب بهتر، کاهش اضطراب و بهبود کیفیت زندگی بیمار است.
    </p>
  
  
    <FeatureGrid>
  
      <FeatureCard
        title="ارزیابی دقیق درد"
        description="بررسی محل، شدت، نوع و عوامل تشدیدکننده درد برای درک بهتر شرایط هر بیمار."
        icon="clipboardList"
      />
  
      <FeatureCard
        title="انتخاب روش مناسب"
        description="استفاده از رویکردهای دارویی و حمایتی متناسب با شرایط بیمار و نوع درد."
        icon="stethoscope"
      />
  
      <FeatureCard
        title="پایش و تنظیم درمان"
        description="ارزیابی پاسخ بیمار به درمان و اصلاح برنامه کنترل درد در صورت نیاز."
        icon="activity"
      />
  
      <FeatureCard
        title="تمرکز بر کیفیت زندگی"
        description="هدف نهایی، کاهش محدودیت‌های ناشی از درد و کمک به زندگی فعال‌تر بیمار است."
        icon="heartPulse"
      />
  
    </FeatureGrid>
  
  </Section>
  <Section background="secondary">

    <SectionHeading
      title="کنترل تهوع و عوارض درمان"
      subtitle="پیشگیری و مدیریت عوارض ناشی از درمان‌های ضد سرطان"
    />
  
    <p>
      برخی درمان‌های سرطان مانند شیمی‌درمانی، ایمونوتراپی و سایر درمان‌های دارویی ممکن است با عوارضی همراه باشند. شناسایی زودهنگام علائم و استفاده از روش‌های مناسب کنترل عوارض، نقش مهمی در ادامه موفقیت‌آمیز درمان دارد.
    </p>
  
    <p>
      برنامه مراقبتی هر بیمار بر اساس نوع درمان، شرایط جسمی، سابقه پزشکی و میزان پاسخ بدن به درمان تنظیم می‌شود تا ضمن حفظ اثربخشی درمان، کیفیت زندگی بیمار نیز حفظ شود.
    </p>
  
  
    <FeatureGrid>
  
      <FeatureCard
        title="پیشگیری از تهوع"
        description="استفاده از روش‌های مناسب برای کاهش احتمال تهوع و ناراحتی‌های گوارشی مرتبط با درمان."
        icon="shield"
      />
  
      <FeatureCard
        title="مدیریت عوارض دارویی"
        description="بررسی و کنترل عوارض احتمالی درمان‌های ضد سرطان با رویکردی فردمحور."
        icon="pill"
      />
  
      <FeatureCard
        title="پایش علائم"
        description="پیگیری منظم وضعیت بیمار برای تشخیص زودهنگام مشکلات و انجام اقدامات لازم."
        icon="activity"
      />
  
      <FeatureCard
        title="حفظ روند درمان"
        description="کمک به بیمار برای ادامه درمان با تحمل بهتر و کاهش اختلال در زندگی روزمره."
        icon="heartHandshake"
      />
  
    </FeatureGrid>
  
  </Section>
  <Section>

    <SectionHeading
      title="مدیریت ضعف، خستگی و بی‌اشتهایی"
      subtitle="کمک به حفظ توان جسمی و کیفیت زندگی در طول درمان"
    />
  
    <p>
      ضعف و خستگی از علائم شایع در بیماران مبتلا به سرطان هستند و می‌توانند به علت خود بیماری، درمان‌ها، کم‌خونی، مشکلات تغذیه‌ای یا عوامل دیگر ایجاد شوند. بررسی علت زمینه‌ای این علائم، اولین قدم برای مدیریت مناسب آن‌ها است.
    </p>
  
    <p>
      مراقبت حمایتی با هدف حفظ توانایی انجام فعالیت‌های روزمره، بهبود وضعیت تغذیه‌ای و کمک به بیمار برای داشتن شرایط بهتر در طول دوره درمان ارائه می‌شود.
    </p>
  
  
    <FeatureGrid>
  
      <FeatureCard
        title="بررسی علت ضعف و خستگی"
        description="ارزیابی عوامل مؤثر مانند کم‌خونی، عوارض درمان، وضعیت تغذیه و شرایط عمومی بیمار."
        icon="clipboardList"
      />
  
      <FeatureCard
        title="حفظ وضعیت تغذیه‌ای"
        description="کمک به مدیریت کاهش اشتها و ارائه توصیه‌های مناسب برای حفظ انرژی و دریافت مواد مورد نیاز بدن."
        icon="heart"
      />
  
      <FeatureCard
        title="بهبود توانایی روزمره"
        description="ارائه راهکارهایی برای مدیریت انرژی و حفظ استقلال بیمار در فعالیت‌های روزانه."
        icon="activity"
      />
  
      <FeatureCard
        title="پیگیری مستمر"
        description="ارزیابی روند علائم و تنظیم اقدامات حمایتی متناسب با تغییرات وضعیت بیمار."
        icon="calendarClock"
      />
  
    </FeatureGrid>
  
  </Section>
  <Section background="secondary">

    <SectionHeading
      title="حفظ کیفیت زندگی در طول درمان"
      subtitle="مراقبت جامع برای همراهی بیمار در تمام مراحل درمان"
    />
  
    <p>
      درمان سرطان تنها به کنترل بیماری محدود نمی‌شود. توجه به وضعیت جسمی، روحی و اجتماعی بیمار بخش مهمی از یک برنامه درمانی جامع است و می‌تواند نقش مهمی در تجربه بهتر مسیر درمان داشته باشد.
    </p>
  
    <p>
      هدف مراقبت حمایتی، همراهی بیمار در کنار درمان‌های اصلی، کاهش مشکلات قابل پیشگیری و کمک به حفظ استقلال، آرامش و کیفیت زندگی در طول دوره درمان است.
    </p>
  
  
    <FeatureGrid>
  
      <FeatureCard
        title="مراقبت فردمحور"
        description="در نظر گرفتن نیازها، شرایط و اولویت‌های هر بیمار در طراحی برنامه مراقبتی."
        icon="heartHandshake"
      />
  
      <FeatureCard
        title="ارتباط مؤثر با تیم درمان"
        description="ایجاد ارتباط مناسب برای بیان علائم، نگرانی‌ها و دریافت راهنمایی‌های لازم در طول درمان."
        icon="messageCircle"
      />
  
      <FeatureCard
        title="حفظ فعالیت‌های روزمره"
        description="کمک به بیمار برای ادامه فعالیت‌های روزمره با توجه به شرایط و توانایی‌های فردی."
        icon="activity"
      />
  
      <FeatureCard
        title="مراقبت جامع"
        description="توجه همزمان به علائم جسمی، کیفیت زندگی و نیازهای بیمار در تمام مراحل درمان."
        icon="heartPulse"
      />
  
    </FeatureGrid>
  
  </Section>
  <Section>

    <SectionHeading
      title="سؤالات متداول"
    />
  
    <Faq items={supportiveFAQ} />
  
  </Section>


</ServiceDetailLayout>