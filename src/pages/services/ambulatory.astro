---
import ServiceDetailLayout from "@/layouts/ServiceDetailLayout.astro";
import Section from "@/components/Section.astro";
import SectionHeading from "@/components/SectionHeading.astro";
import FeatureGrid from "@/components/FeatureGrid.astro";
import FeatureCard from "@/components/FeatureCard.astro";
import { getService } from "@/lib/getService";
import Faq from "@/components/Faq.astro";
import { ambulatoryFAQ } from "@/data/ambulatoryFAQ";

const service = getService("ambulatory");
---

<ServiceDetailLayout service={service}>

  <Section>

    <SectionHeading
      title="اقدامات سرپایی چیست؟"
      subtitle="ارائه خدمات درمانی ایمن بدون نیاز به بستری طولانی"
    />

    <p>
      بسیاری از خدمات درمانی در حوزه هماتولوژی و انکولوژی می‌توانند به صورت سرپایی و تحت نظارت پزشک انجام شوند. این خدمات به بیمار امکان می‌دهند درمان یا مراقبت مورد نیاز را دریافت کند و در همان روز به فعالیت‌های معمول خود بازگردد.
    </p>

    <p>
      انجام خدمات سرپایی با بررسی شرایط بیمار، ارزیابی نیازهای درمانی و رعایت اصول ایمنی انجام می‌شود تا کیفیت مراقبت حفظ شود.
    </p>

  </Section>
  <Section background="secondary">

    <SectionHeading
      title="چه خدماتی ارائه می‌شود؟"
      subtitle="خدمات درمانی و حمایتی قابل انجام به صورت سرپایی"
    />
  
    <FeatureGrid>
  
      <FeatureCard
        title="سرم‌تراپی"
        description="ارائه مایعات و درمان‌های تزریقی مورد نیاز بیمار با توجه به شرایط بالینی و نظر پزشک."
        icon="activity"
      />
  
      <FeatureCard
        title="تزریق فرآورده‌های آهن"
        description="ارزیابی کمبود آهن و انجام درمان تزریقی در بیمارانی که بر اساس شرایط پزشکی به این روش نیاز دارند."
        icon="flaskConical"
      />
  
      <FeatureCard
        title="درمان‌های علامتی"
        description="ارائه درمان‌های لازم برای کنترل برخی علائم و عوارض ناشی از بیماری یا درمان‌ها."
        icon="pill"
      />
  
      <FeatureCard
        title="پایش وضعیت بیمار"
        description="بررسی شرایط بیمار قبل، حین و پس از دریافت خدمات برای اطمینان از ایمنی و کیفیت مراقبت."
        icon="heartPulse"
      />
  
    </FeatureGrid>
  
  </Section>
  <Section>

    <SectionHeading
      title="سرم‌تراپی و درمان‌های حمایتی"
      subtitle="کمک به بهبود شرایط بیمار و تأمین نیازهای درمانی در طول مسیر مراقبت"
    />
  
    <p>
      در برخی بیماران، دریافت مایعات یا داروهای تزریقی به صورت سرپایی می‌تواند بخشی از برنامه درمانی یا مراقبتی باشد. نوع و میزان درمان بر اساس وضعیت بالینی بیمار، نتایج بررسی‌ها و نظر پزشک تعیین می‌شود.
    </p>
  
    <p>
      هدف از این خدمات، کمک به کنترل علائم، بهبود تحمل درمان‌ها و حمایت از وضعیت عمومی بیمار در شرایط مناسب است.
    </p>
  
  
    <FeatureGrid>
  
      <FeatureCard
        title="ارزیابی قبل از درمان"
        description="بررسی شرایط عمومی بیمار، آزمایش‌ها و نیازهای درمانی پیش از انجام خدمات سرپایی."
        icon="clipboardList"
      />
      
      <FeatureCard
        title="جبران کم‌آبی بدن"
        description="ارائه مایعات تزریقی در شرایطی که بیمار به دلیل بیماری یا درمان‌ها نیاز به حمایت بیشتری دارد."
        icon="activity"
      />
  
      <FeatureCard
        title="دریافت داروهای حمایتی"
        description="تزریق برخی داروهای مورد نیاز برای کنترل علائم یا کاهش عوارض درمان‌ها بر اساس نظر پزشک."
        icon="pill"
      />
  
      <FeatureCard
        title="نظارت پزشکی"
        description="بررسی وضعیت بیمار در زمان دریافت درمان برای افزایش ایمنی و اطمینان از پاسخ مناسب."
        icon="stethoscope"
      />
  
    </FeatureGrid>
  
  </Section>
  <Section background="secondary">

    <SectionHeading
      title="تزریق فرآورده‌های آهن"
      subtitle="درمان کمبود آهن در بیمارانی که به درمان تزریقی نیاز دارند"
    />
  
    <p>
      کمبود آهن یکی از علل شایع کم‌خونی است و در برخی بیماران، درمان خوراکی آهن ممکن است کافی نباشد، تحمل نشود یا برای اصلاح وضعیت بیمار مناسب نباشد. در این شرایط، پزشک ممکن است درمان با فرآورده‌های آهن تزریقی را در نظر بگیرد.
    </p>
  
    <p>
      انتخاب نوع فرآورده آهن، مقدار مورد نیاز و زمان‌بندی تزریق بر اساس نتایج آزمایش‌ها، شرایط بیمار و علت کمبود آهن تعیین می‌شود.
    </p>
  
  
    <FeatureGrid>
  
      <FeatureCard
        title="ارزیابی کمبود آهن"
        description="بررسی آزمایش‌های مرتبط مانند وضعیت آهن بدن برای تشخیص دقیق نیاز به درمان."
        icon="fileText"
      />
  
      <FeatureCard
        title="انتخاب روش مناسب درمان"
        description="تصمیم‌گیری درباره درمان تزریقی بر اساس شرایط فردی، پاسخ به درمان‌های قبلی و نیاز بیمار."
        icon="stethoscope"
      />
  
      <FeatureCard
        title="تزریق تحت نظارت"
        description="انجام تزریق با رعایت اصول ایمنی و بررسی وضعیت بیمار در طول دریافت درمان."
        icon="shield"
      />
  
      <FeatureCard
        title="پیگیری پاسخ درمان"
        description="ارزیابی نتایج درمان و بررسی بهبود وضعیت خونی بیمار در زمان مناسب."
        icon="calendarClock"
      />
  
    </FeatureGrid>
  
  </Section>
  <Section>

    <SectionHeading
      title="درمان‌های علامتی"
      subtitle="کنترل علائم و عوارض در شرایطی که نیاز به مراقبت سرپایی وجود دارد"
    />
  
    <p>
      در طول بیماری یا درمان‌های مختلف، برخی بیماران ممکن است دچار علائمی شوند که نیاز به ارزیابی و درمان دارند. بسیاری از این مشکلات در صورت مناسب بودن شرایط بیمار می‌توانند به صورت سرپایی و تحت نظارت پزشکی مدیریت شوند.
    </p>
  
    <p>
      هدف از درمان‌های علامتی، کاهش ناراحتی بیمار، پیشگیری از تشدید علائم و کمک به ادامه بهتر روند درمان اصلی است.
    </p>
  
  
    <FeatureGrid>
  
      <FeatureCard
        title="کنترل علائم ناشی از درمان"
        description="ارزیابی و مدیریت برخی عوارض مرتبط با درمان‌های ضد سرطان یا سایر درمان‌های پزشکی."
        icon="activity"
      />
  
      <FeatureCard
        title="درمان حمایتی دارویی"
        description="استفاده از درمان‌های مناسب برای کاهش علائم بر اساس شرایط و نیازهای هر بیمار."
        icon="pill"
      />
  
      <FeatureCard
        title="کاهش نیاز به بستری"
        description="ارائه مراقبت‌های مناسب در محیط سرپایی در بیمارانی که شرایط دریافت این خدمات را دارند."
        icon="heartHandshake"
      />
  
      <FeatureCard
        title="ادامه مسیر درمان"
        description="هماهنگی مراقبت‌های حمایتی با برنامه اصلی درمان برای حفظ کیفیت و ایمنی مراقبت."
        icon="calendarClock"
      />
  
    </FeatureGrid>
  
  </Section>
  <Section background="secondary">

    <SectionHeading
      title="ایمنی و پایش بیمار در خدمات سرپایی"
      subtitle="ارائه مراقبت دقیق پیش از، حین و پس از دریافت خدمات درمانی"
    />
  
    <p>
      خدمات سرپایی زمانی انجام می‌شوند که شرایط بیمار برای دریافت این نوع مراقبت مناسب باشد. پیش از انجام درمان، وضعیت عمومی بیمار بررسی شده و در طول دریافت خدمات نیز پایش‌های لازم انجام می‌شود.
    </p>
  
    <p>
      هدف از این روند، افزایش ایمنی درمان، شناسایی سریع مشکلات احتمالی و اطمینان از ادامه مناسب مسیر مراقبت است.
    </p>
  
  
    <FeatureGrid>
  
      <FeatureCard
        title="ارزیابی پیش از درمان"
        description="بررسی شرایط بالینی، علائم، آزمایش‌ها و نیازهای بیمار قبل از شروع خدمات."
        icon="clipboardList"
      />
  
      <FeatureCard
        title="پایش حین درمان"
        description="نظارت بر وضعیت بیمار هنگام دریافت خدمات برای اطمینان از ایمنی و تحمل مناسب درمان."
        icon="activity"
      />
  
      <FeatureCard
        title="مدیریت واکنش‌های احتمالی"
        description="آمادگی برای شناسایی و رسیدگی به عوارض یا واکنش‌های احتمالی مرتبط با درمان."
        icon="shield"
      />
  
      <FeatureCard
        title="پیگیری پس از درمان"
        description="ارزیابی روند بهبودی و هماهنگی اقدامات بعدی بر اساس وضعیت بیمار."
        icon="calendarClock"
      />
  
    </FeatureGrid>
  
  </Section>
  <Section background="secondary">

    <SectionHeading
      title="سؤالات متداول"
    />
  
    <Faq items={ambulatoryFAQ} />
  
  </Section>


</ServiceDetailLayout>