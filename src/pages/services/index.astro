---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Hero from "../../components/Hero.astro";
import Section from "../../components/Section.astro"
import SectionHeading from "../../components/SectionHeading.astro";
import ServiceGrid from "../../components/ServiceGrid.astro";
import ServiceCard from "../../components/ServiceCard.astro";
import servicesImage from "../../assets/images/Services.png"
import FeatureGrid from "../../components/FeatureGrid.astro";
import FeatureCard from "../../components/FeatureCard.astro";
import ProcessGrid from "../../components/ProcessGrid.astro";
import ProcessStep from "../../components/ProcessStep.astro";
import Faq from "../../components/Faq.astro";
import Cta from "../../components/Cta.astro";
const faqItems = [
  {
    question: "آیا برای ویزیت اولیه مدارک قبلی لازم است؟",
    answer: "بله، لطفاً تمامی آزمایش‌ها، تصویربرداری‌ها و گزارش‌های پزشکی قبلی را همراه داشته باشید."
  },
  {
    question: "بیوپسی مغز استخوان چگونه انجام می‌شود؟",
    answer: "این اقدام به صورت سرپایی و با بی‌حسی موضعی انجام می‌شود."
  },
  {
    question: "آیا خدمات شیمی درمانی در مطب انجام می‌شود؟",
    answer: "بیشتر موارد شیمی درمانی‌ها در مطب قابل انجام است. در مواردی که نیاز به درمان چند روزه باشد یا زمان تزریق طولانی باشد،ممکن است بیمار بستری گردد."
  }
];
---

<BaseLayout
    title="خدمات"
    description="توضیحات کامل در مورد خدمات ارائه شده شامل ویزیت، مشاوره، شیمی درمانی، نمونه برداری از مغز استخوان و غیره"
    image="/default-og-image.jpg"
	>
    <Hero 
    badge="مطب فوق تخصصی هماتولوژی و آنکولوژی"
    titleLine1="خدمات تخصصی"
    titleLine2="آنکولوژی و هماتولوژی"
    description="ارائه خدمات تشخیصی، درمانی و مراقبتی برای بیماران مبتلا به سرطان، بیماری‌های خونی و اختلالات هماتولوژیک"
    image={servicesImage}
    alt="warm clinic environment"
    >
    </Hero>
    <Section
    background="primary"
    >
        <SectionHeading
        title="خدمات تخصصی"
         subtitle="خدمات تشخیصی و درمانی در حوزه آنکولوژی و هماتولوژی"
        >
        </SectionHeading>
        <ServiceGrid>
            <ServiceCard 
            title="درمان‌های سرطان"
            description="شیمی درمانی، ایمونوتراپی، درمان‌های هدفمند و پیگیری درمان بیماران مبتلا به سرطان"
            href="/services/medical-oncology"
            icon="/assets/icons/ribbon.svg"
            >
            </ServiceCard>
            <ServiceCard
            title="بیماری‌های خونی"
            description="ارزیابی و درمان کم‌خونی، اختلالات انعقادی و سایر بیماری‌های هماتولوژیک"
            href="/services/hematology"
            icon="/assets/icons/blood.svg"
            >
            </ServiceCard>
            <ServiceCard
            title="اقدامات تخصصی"
            description="بیوپسی مغز استخوان، آسپیراسیون، LP و شیمی‌درمانی داخل نخاعی  "
            href="/services/procedures"
            icon="/assets/icons/syringe.svg"
            >
            </ServiceCard>
            <ServiceCard
            title="مراقبت حمایتی"
            description="کنترل علمی دردهای سرطانی، تهوع، ضعف و بی‌اشتهایی ناشی از درمان‌ها جهت ارتقای جدی کیفیت زندگی (Quality of Life) بیماران در طول دوره درمان"
            href="/services/supportive"
            icon="/assets/icons/supportive.svg"
            >
            </ServiceCard>
            <ServiceCard
            title="اقدامات سرپایی"
            description="سرم تراپی، تزریق فرآورده‌های آهن، درمانهای علامتی"
            href="/services/ambulatory"
            icon="/assets/icons/ambulatory.svg"
            >
            </ServiceCard>
            <ServiceCard
            title="مشاوره تخصصی دوم (Second Opinion)"
            description="بررسی دقیق پرونده‌های پیچیده پزشکی، پاتولوژی و گرافی‌ها جهت تایید تشخیص و ارائه بهترین و دقیق‌ترین پیشنهاد درمانی نوین"
            href="/services/consult"
            icon="/assets/icons/consult.svg"
            >
            </ServiceCard>
        </ServiceGrid>
    </Section>
    <Section
    background="secondary">
    <SectionHeading 
    title="چرا ما را انتخاب کنید؟"
    subtitle="ارائه خدمات تخصصی با رویکردی بیمارمحور"
    >
    </SectionHeading>
    <FeatureGrid>
        <FeatureCard 
        title="درمان مبتنی بر شواهد"
        description="استفاده از جدیدترین راهنماهای علمی و استانداردهای بین‌المللی درمان"
        icon="/assets/icons/evidence.svg">
    </FeatureCard>
    <FeatureCard
    title="برنامه درمانی فردمحور"
    description="طراحی برنامه درمانی متناسب با شرایط و نیازهای هر بیمار"
    icon="/assets/icons/personalized.svg"
    >
    </FeatureCard>
    <FeatureCard
    title="پیگیری مستمر"
    description="ارزیابی منظم روند درمان و مدیریت عوارض احتمالی"
    icon="/assets/icons/followup.svg"
    >
    </FeatureCard>
    <FeatureCard
    title="مراقبت جامع"
    description="توجه به کیفیت زندگی بیمار در تمام مراحل درمان"
    icon="/assets/icons/life.svg"
    >
    </FeatureCard>
    </FeatureGrid>
    </Section>
    <Section>
        <SectionHeading
        title="روند مراجعه بیمار"
        subtitle="مراحل دریافت خدمات تخصصی">
        </SectionHeading>
        <ProcessGrid>
            <ProcessStep
            number={1}
            title="رزرو نوبت"
            description="از طریق تماس یا واتساپ"
            >
            </ProcessStep>
            <ProcessStep
            number={2}
            title="ویزیت اولیه"
            description="بررسی سوابق و مدارک پزشکی"
            >
            </ProcessStep>
            <ProcessStep
            number={3}
            title="تشخیص"
            description="تعیین برنامه درمانی مناسب"
            >
            </ProcessStep>
            <ProcessStep
            number={4}
            title="درمان"
            description="شروع درمان یا انجام پروسیجر"
            >
            </ProcessStep>
            <ProcessStep
            number={5}
            title="پیگیری"
            description="ارزیابی و مراقبت مستمر"
            >
            </ProcessStep>
        </ProcessGrid>
    </Section>
    <Section background="secondary">
        <SectionHeading 
        title="سوالات متداول">
        </SectionHeading>
        <Faq 
        items={faqItems}>
        </Faq>

    </Section>
    <Cta 
    title="دریافت مشاوره تخصصی"
    description="جهت رزرو نوبت یا دریافت اطلاعات بیشتر با ما تماس بگیرید"
    >

    </Cta>
</BaseLayout>