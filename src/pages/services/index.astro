---
import { services } from "@/data/services";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Hero from "@/components/Hero.astro";
import Section from "@/components/Section.astro"
import SectionHeading from "@/components/SectionHeading.astro";
import ServiceGrid from "@/components/ServiceGrid.astro";
import ServiceCard from "@/components/ServiceCard.astro";
import servicesImage from "@/assets/images/Services.png"
import FeatureGrid from "@/components/FeatureGrid.astro";
import FeatureCard from "@/components/FeatureCard.astro";
import ProcessGrid from "@/components/ProcessGrid.astro";
import ProcessStep from "@/components/ProcessStep.astro";
import Faq from "@/components/Faq.astro";
import Cta from "@/components/Cta.astro";
import {servicesFAQ} from "@/data/servicesFAQ.ts"
import ButtonLink from "@/components/ButtonLink.astro";

---

<BaseLayout
    title="خدمات"
    description="توضیحات کامل در مورد خدمات ارائه شده شامل ویزیت، مشاوره، شیمی درمانی، نمونه برداری از مغز استخوان و غیره"
    image="/default-og-image.jpg"
	>
    <Hero 
    badge="مطب فوق تخصصی هماتولوژی و آنکولوژی"
    titleLine1="خدمات تخصصی"
    titleLine2="آنکولوژی و هماتولوژی"
    description="ارائه خدمات تشخیصی، درمانی و مراقبتی برای بیماران مبتلا به سرطان، بیماری‌های خونی و اختلالات هماتولوژیک"
    image={servicesImage}
    alt="warm clinic environment"
    >
    </Hero>
    <Section>
        <SectionHeading
        title="خدمات تخصصی"
         subtitle="خدمات تشخیصی و درمانی در حوزه آنکولوژی و هماتولوژی"
        >
        </SectionHeading>
        <ServiceGrid>

            {Object.entries(services).map(([slug, service]) => (
              <ServiceCard
                title={service.title}
                description={service.description}
                href={`/services/${slug}`}
                icon={service.icon}
              />
            ))}
          
          </ServiceGrid>
    </Section>
    <Section
    background="secondary">
    <SectionHeading 
    title="چرا ما را انتخاب کنید؟"
    subtitle="ارائه خدمات تخصصی با رویکردی بیمارمحور"
    >
    </SectionHeading>
    <FeatureGrid>
        <FeatureCard 
        title="درمان مبتنی بر شواهد"
        description="استفاده از جدیدترین راهنماهای علمی و استانداردهای بین‌المللی درمان"
        icon="evidence">
    </FeatureCard>
    <FeatureCard
    title="برنامه درمانی فردمحور"
    description="طراحی برنامه درمانی متناسب با شرایط و نیازهای هر بیمار"
    icon="personalized"
    >
    </FeatureCard>
    <FeatureCard
    title="پیگیری مستمر"
    description="ارزیابی منظم روند درمان و مدیریت عوارض احتمالی"
    icon="followup"
    >
    </FeatureCard>
    <FeatureCard
    title="مراقبت جامع"
    description="توجه به کیفیت زندگی بیمار در تمام مراحل درمان"
    icon="life"
    >
    </FeatureCard>
    </FeatureGrid>
    </Section>
    <Section>
        <SectionHeading
        title="روند مراجعه بیمار"
        subtitle="مراحل دریافت خدمات تخصصی">
        </SectionHeading>
        <ProcessGrid>
            <ProcessStep
            number={1}
            title="رزرو نوبت"
            description="از طریق تماس یا واتساپ"
            icon="calendarCheck"
            >
            </ProcessStep>
            <ProcessStep
            number={2}
            title="ویزیت اولیه"
            description="بررسی سوابق و مدارک پزشکی"
            icon="userPlus"
            >
            </ProcessStep>
            <ProcessStep
            number={3}
            title="تشخیص"
            description="تعیین برنامه درمانی مناسب"
            icon="stethoscope"
            >
            </ProcessStep>
            <ProcessStep
            number={4}
            title="درمان"
            description="شروع درمان یا انجام پروسیجر"
            icon="pill"
            >
            </ProcessStep>
            <ProcessStep
            number={5}
            title="پیگیری"
            description="ارزیابی و مراقبت مستمر"
            icon="calendarClock"
            >
            </ProcessStep>
        </ProcessGrid>
    </Section>
    <Section background="secondary">
        <SectionHeading 
        title="سوالات متداول">
        </SectionHeading>
        <Faq 
        items={servicesFAQ}>
        </Faq>

    </Section>
    <Cta 
    title="درباره خدمات ما پرسشی دارید؟"
    description="جهت رزرو نوبت یا دریافت اطلاعات بیشتر با ما تماس بگیرید"
    >
    <ButtonLink
    href="/consultation"
    text="مشاوره آنلاین"
  />

  <ButtonLink
    href="/visit"
    variant="secondary"
    text="رزرو نوبت"
  />
    </Cta>
</BaseLayout>