---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import visitImage from "../assets/images/visit.webp";
import Section from "../components/Section.astro";
import NoticeBanner from "../components/NoticeBanner.astro";
import { doctors } from "../data/doctors";
import DoctorScheduleCard from "../components/DoctorScheduleCard.astro";
import SectionHeading from "../components/SectionHeading.astro";
import ContactGrid from "../components/ContactGrid.astro";
import ReservationCard from "../components/ReservationCard.astro";
import Faq from "../components/Faq.astro";
import Cta from "../components/Cta.astro";

const faqItems = [
    {
        question: "چگونه می‌توانم نوبت ویزیت بگیرم؟",
        answer: "برای دریافت نوبت، می‌توانید در ساعات کاری با شماره تلفن مطب یا کلینیک تماس بگیرید. همکاران ما با توجه به برنامه حضور پزشک، نزدیک‌ترین زمان ممکن را برای ویزیت شما تعیین خواهند کرد."
    }, {
        question: "آیا مراجعه بدون نوبت امکان‌پذیر است؟", 
        answer: "به منظور کاهش زمان انتظار بیماران، ویزیت‌ها تنها با تعیین وقت قبلی انجام می‌شوند. در شرایط خاص، لطفاً پیش از مراجعه با مطب تماس بگیرید."
    }, {
        question: "هنگام مراجعه چه مدارکی باید همراه داشته باشم؟", 
        answer: "لطفاً مدارک شناسایی، دفترچه یا بیمه (در صورت نیاز)، نتایج آزمایش‌ها، گزارش‌های تصویربرداری، پاتولوژی، نسخه‌های قبلی و فهرست داروهای مصرفی خود را همراه داشته باشید. همراه داشتن این مدارک به ارزیابی دقیق‌تر وضعیت شما کمک می‌کند."
    }, {
        question: "اولین ویزیت معمولاً چقدر زمان می‌برد؟", 
        answer: "اولین جلسه ویزیت معمولاً نسبت به مراجعات بعدی زمان بیشتری نیاز دارد، زیرا سوابق پزشکی، نتایج بررسی‌ها و برنامه درمانی به طور کامل بررسی و درباره آن با بیمار گفتگو می‌شود."
    }, {
        question: "اگر نتوانم در زمان تعیین‌شده مراجعه کنم چه کار باید انجام دهم؟", 
        answer: "خواهشمندیم در صورت امکان، حداقل ۲۴ ساعت قبل از زمان ویزیت با مطب یا کلینیک تماس بگیرید تا نوبت شما به بیمار دیگری اختصاص داده شود و زمان جدیدی برای شما هماهنگ گردد."
    }, {
        question: "آیا امکان مشاوره برای دریافت نظر دوم (Second Opinion) وجود دارد؟", 
        answer: "بله. در صورت تمایل به دریافت نظر دوم درباره تشخیص یا برنامه درمانی، می‌توانید تمام مدارک پزشکی خود را همراه داشته باشید تا به دقت بررسی شوند."
    }
];
---

<BaseLayout
    title="ویزیت"
    description="روزها و ساعات ویزیت حضوری پزشکان در کلینیک و بیمارستان"
    image="/default-og-image.jpg"
	>
    <Hero 
        badge="زمان‌بندی ویزیت"
        titleLine1="برنامه حضور پزشکان"
        titleLine2="در مطب و بیمارستان"
        description="لطفاً پیش از مراجعه حضوری، برنامه زمان‌بندی زیر را بررسی نموده و جهت هماهنگی نهایی با شماره‌های مطب تماس حاصل فرمایید."
        image={visitImage}
        alt="تصویر اتاق انتظار کلینیک"
    >

    </Hero>
    <Section background="primary">
        <NoticeBanner

    type="warning"

    title="توجه"

    text="برنامه حضور پزشکان ممکن است در ایام تعطیل یا مناسبت‌های رسمی تغییر کند. لطفاً پیش از مراجعه با مطب تماس بگیرید."

/>
    </Section>
    <Section background="secondary">
        {doctors.map((doctor) => (

        <DoctorScheduleCard
    
            {...doctor}
            >
            </DoctorScheduleCard>
    
        
    
    ))}
    </Section>
    <Section background="primary">
        <SectionHeading 
        title="رزرو نوبت"
        >
            
        </SectionHeading>
        <ContactGrid>
            <ReservationCard 
                title="مطب "
                address="تهران،صادقیه،خ ستارخان،بلوار شهدای صادقیه،خ پرویز،پ ۱۵، طبقه ششم"
                phone="۰۲۱۴۶۱۲۹۱۴۳"
                href="tel://+982146129143/"
            >

            </ReservationCard>
            <ReservationCard 
                title="بیمارستان "
                address="تهران،صادقیه،خ ستارخان،بلوار شهدای صادقیه،خ پرویز،پ ۱۵، طبقه ششم"
                phone="۰۲۱۴۶۱۲۹۱۴۳"
                href="tel://+982146129143/"
            >

            </ReservationCard>
        </ContactGrid>
    </Section>
    <Section>
        <SectionHeading 
        title="سوالات متداول">
        </SectionHeading>
        <Faq 
        items={faqItems}>
        </Faq>
    </Section>
    <Cta 
    title="اطلاعات بیشتری نیاز دارید؟"
    description="برای گرفتن نوبت ویزیت حضوری یا مشاوره آنلاین اقدام کنید"
    >

    </Cta>
    
</BaseLayout>