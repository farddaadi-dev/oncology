---
import ButtonLink from "./ButtonLink.astro";
import {Image} from "astro:assets";
interface Props {
    badge: string;
    title?: string;
    titleLine1?: string;
    titleLine2?: string;
    description: string;
    image?: ImageMetadata;
    alt?: string;

    showButtons?: boolean;

    primaryButtonText?: string;
    primaryButtonHref?: string;

    secondaryButtonText?: string;
    secondaryButtonHref?: string;
}
const {
    badge,
    title,
    titleLine1,
    titleLine2,
    description,
    image,
    alt,

    showButtons = true,

    primaryButtonText = "مشاوره آنلاین",
    primaryButtonHref = "/consultation",

    secondaryButtonText = "ویزیت حضوری",
    secondaryButtonHref = "/visit",

} = Astro.props;
---

<section class="hero">
    <div class="container-hero">
        <div class="content">
            <div class="badge animate-fade-up delay-1">{badge}</div>
            <h1 class:list={[
                "hero-title",
                "animate-fade-up",
                "delay-2",
                { "hero-title--single": title }
            ]}>

                {title ? (
                    title
                ) : (
                    <>
                        {titleLine1}
                        {titleLine2 && (
                            <>
                                <br />
                                {titleLine2}
                            </>
                        )}
                    </>
                )}
            
            </h1>
            <p class="description animate-fade-up delay-3">
                {description}
            </p>
            {
                showButtons && (

                    <div class="hero-button animate-fade-up delay-4">

                        <ButtonLink
                            href={primaryButtonHref}
                            text={primaryButtonText}
                        />

                        <ButtonLink
                            href={secondaryButtonHref}
                            variant="secondary"
                            text={secondaryButtonText}
                        />

                    </div>

                )
            }
        </div>
        {image && (
            <div class="visual animate-fade-left delay-2">
                <Image 
                    class="heroImg" 
                    src={image} 
                    alt={alt ?? title ?? titleLine1 ?? ""} 
                />
            </div>
        )}
    </div>
</section>

<style>
    .hero {
        padding: 5rem 1.25rem;
        background-color: var(--color-bg-hero);
        overflow: hidden;
    }
    .container-hero {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 40px;

    }
    .content {
        max-width: 700px;
        flex: 1;
    }
    .badge {
        display: inline-block;
        background-color: var(--color-brand-green-light);
        color: white;
        padding: 6px 14px;
        border-radius: 20px;
        font-size: 1.1rem;
        margin-bottom: 20px;
    }
    .hero-title {
        font-size: 2.5rem;
        line-height: 1.4;
        color: var(--color-text-heading);
        font-weight: 700;
        text-shadow: 1px 1px 1px var(--color-brand-accent);
        margin-bottom: 1.25rem;
        font-family: var(--font-estedad);
    }

    .hero-title--single {
    font-size: 3rem;
    line-height: 1.2;
}

    .description {
        font-size: 1.15rem;
        line-height: 1.9;
        color: var(--color-text-primary);
        margin-bottom: 2rem;
    }
    .hero-button {
        display: flex;
        gap: 1rem;
    }
    .visual {
        width: 100%;
        max-width: 700px;
        flex: 1;
    }
    .heroImg {
        border-radius: 12px;
        object-fit: cover;
        box-shadow: 0 15px 35px rgba(26, 46, 38, 0.08);

    }
    .animate-fade-up {
    opacity: 0; 
    animation: fadeInUp 0.8s cubic-bezier(0.25, 1, 0.5, 1) forwards;
}

.animate-fade-left {
    opacity: 0;
    animation: fadeInLeft 1s cubic-bezier(0.25, 1, 0.5, 1) forwards;
}


.delay-1 { animation-delay: 0.1s; }
.delay-2 { animation-delay: 0.3s; }
.delay-3 { animation-delay: 0.5s; }
.delay-4 { animation-delay: 0.7s; }

@keyframes fadeInUp {
    from {
        opacity: 0;
        transform: translateY(25px); /* Slides smoothly upwards */
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

@keyframes fadeInLeft {
    from {
        opacity: 0;
        transform: translateX(-30px); /* Slides smoothly from the left side */
    }
    to {
        opacity: 1;
        transform: translateX(0);
    }
}

@keyframes gentleFloat {
    0% { transform: translateY(0px); }
    50% { transform: translateY(-8px); } /* Softly hovers up and down */
    100% { transform: translateY(0px); }
}
</style>

<style is:global>
    @media (max-width: 992px) {
    .container-hero {
        flex-direction: column; 
        text-align: center;
        padding-top: 20px;
    }
    
      
    .hero-title {
        font-size: 2rem;
    }
    
    .hero-button {
        flex-direction: column;
        gap: 12px;
    }
}

</style>
