---
import ScheduleRow from "./ScheduleRow.astro";

interface Session {

    day:string;

    hours:string;

}

interface Location {

    name:string;

    phone:string;

    sessions:Session[];

}

interface Props {

    name:string;

    specialty:string;

    image?:string;

    locations:Location[];

}

const {

    name,

    specialty,

    image,

    locations

}=Astro.props;
---

<article class="card doctor-card" id="doctor-card">

    {image && (

        <div class="doctor-image">

            <img
                src={image}
                alt={name}
            />

        </div>

    )}

    <div class="doctor-content">

        <h3>{name}</h3>

        <p class="specialty">

            {specialty}

        </p>

        {locations.map(location => (

            <section class="location">

                <div class="location-header">

                    <h4>{location.name}</h4>

                    <a href={`tel:${location.phone}`}>

                        📞 {location.phone}

                    </a>

                </div>

                <div class="schedule">

                    {location.sessions.map(session => (

                        <ScheduleRow

                            day={session.day}

                            hours={session.hours}

                        />

                    ))}

                </div>

            </section>

        ))}

    </div>

</article>

<style>

.doctor-card{

    display:grid;

    grid-template-columns:220px 1fr;

    gap:2rem;

    align-items:start;
    padding:var(--space-lg);

}

.doctor-image img{

    width:100%;

    display:block;

    border-radius:var(--radius-lg);

}

h3 {
    color: var(--color-text-primary)
}

.specialty{

    color:var(--color-text-secondary);

    margin-bottom:2rem;

}

.location{

    margin-top:2rem;

    padding-top:2rem;

    border-top:1px solid var(--color-border);

}

.location:first-of-type{

    margin-top:0;

    padding-top:0;

    border-top:none;

}

.location-header{

    
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: var(--space-md);

    margin-bottom: var(--space-md);
}



.location-header h4{

    margin:0;

    color:var(--color-brand-green);

}

.location-header a{

    text-decoration:none;

    color:var(--color-brand-accent);

    font-weight:600;

}

.schedule{

    display:grid;

    gap:.25rem;
    padding-inline: var(--space-lg);

}

</style>

<style is:global>
    @media(max-width:768px){

    #doctor-card{

        grid-template-columns:1fr;

    }

}
</style>