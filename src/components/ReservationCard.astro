---
import ButtonLink from './ButtonLink.astro';
interface Props {
  title: string;
  phone: string;
  address: string;
  href: string;
}

const { title, phone, href, address } = Astro.props;
---

<article class="service-card">
  

  <h3>{title}</h3>

  <p>{address}</p>
  <p>{phone}</p>

  <ButtonLink 
  href={href}
  text='تماس'
  variant='secondary'
  >
  </ButtonLink>
  
</article>

<style>
  .service-card {
    background: var(--color-bg-hero);
    border-radius: 1rem;
    padding: 2rem;
    box-shadow: 0 4px 4px rgba(0, 0, 0, 0.08);

    display: flex;
    flex-direction: column;
    gap: 1rem;

    transition:
      transform 0.3s ease,
      box-shadow 0.3s ease;

    height: 100%;
  }

  .service-card:hover {
    transform: translateY(-6px);

    box-shadow:
      0 10px 30px rgba(0, 0, 0, 0.12);
  }

  
  .service-card h3 {
    margin: 0;

    font-size: 1.4rem;
    font-weight: 700;

    color: var(--color-text-primary);
  }

  .service-card p {
    margin: 0;

    color: #555;
    line-height: 1.8;

    flex-grow: 1;
  }
</style>