---
import Section from "@/components/Section.astro";
import SectionHeading from "@/components/SectionHeading.astro";
import ProcessStep from "@/components/ProcessStep.astro";

import { expectations } from "@/data/whatToExpect";
---

<Section>

  <SectionHeading
    subtitle="همراهی با شما"
    title="در طول مسیر درمان چه انتظاری می‌توانید داشته باشید؟"
    description="از نخستین ویزیت تا پیگیری‌های درمان، تلاش می‌کنیم تجربه‌ای شفاف، منظم و همراه با احترام و آرامش برای شما فراهم کنیم."
  />

  <div
    class="expectation-grid"
    id="expectation-grid"
  >

    {expectations.map((step) => (

      <ProcessStep
        number={step.number}
        title={step.title}
        description={step.description}
        icon={step.icon}
      />

    ))}

  </div>

</Section>

<style>

.expectation-grid {

  position: relative;

  display: grid;

  grid-template-columns: repeat(4, 1fr);

  gap: 2rem;

  margin-top: 3rem;

}

/* .expectation-grid::before {

  content: "";

  position: absolute;

  top: 2.25rem;

  left: 12%;

  right: 12%;

  height: 2px;

  background:
    linear-gradient(
      to left,
      var(--color-brand-accent),
      color-mix(
        in srgb,
        var(--color-brand-accent) 20%,
        white
      )
    );

  z-index: 0;

}

.expectation-grid > * {

  position: relative;

  z-index: 1;

} */

</style>

<style is:global>

@media (max-width: 1100px) {

  #expectation-grid {

    grid-template-columns: repeat(2, 1fr);

  }

  #expectation-grid::before {

    display: none;

  }

}

@media (max-width: 768px) {

  #expectation-grid {

    grid-template-columns: 1fr;

  }

}

</style>