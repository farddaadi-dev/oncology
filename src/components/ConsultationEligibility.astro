---
import Section from "./Section.astro";
import SectionHeading from "./SectionHeading.astro";
import InfoCard from "./InfoCard.astro";
import IconList from "./IconList.astro";
import NoticeBox from "./NoticeBox.astro";

import { consultationEligibility } from "@/data/onlineConsultation";

import CheckIcon from "@/assets/icons/check.svg";
import AlertIcon from "@/assets/icons/triangle-alert.svg";
---

<Section>

  <SectionHeading
    subtitle="راهنمای انتخاب"
    title="چه زمانی مشاوره آنلاین انتخاب مناسبی است؟"
    description="مشاوره آنلاین برای بسیاری از پرسش‌ها و پیگیری‌های درمانی گزینه‌ای مناسب است، اما در برخی شرایط مراجعه حضوری یا مراجعه فوری به اورژانس ضروری خواهد بود."
  />

  <div class="eligibility-grid" id="eligibility-grid">

    <!-- Suitable for online consultation -->
    <InfoCard
      title="مناسب برای مشاوره آنلاین"
      icon={CheckIcon.src}
    >

      <IconList
        items={consultationEligibility.suitable}
        icon={CheckIcon.src}
      />

    </InfoCard>


    <!-- Urgent situations -->
    <InfoCard
      title="نیازمند مراجعه فوری"
      icon={AlertIcon.src}
      
    >

      <IconList
        items={consultationEligibility.urgent}
        icon={AlertIcon.src}
      />


      <div class="notice-wrapper">

        <NoticeBox
          icon={AlertIcon.src}
          color="var(--color-danger)"
          background="var(--color-danger-bg)"
        >

          <p>
            <strong>توجه:</strong>
            در صورت وجود هر یک از شرایط فوق، ابتدا به نزدیک‌ترین مرکز درمانی یا
            اورژانس مراجعه کنید. مشاوره آنلاین جایگزین خدمات اورژانسی نیست.
          </p>

        </NoticeBox>

      </div>

    </InfoCard>

  </div>

</Section>


<style>
.eligibility-grid {

  display: grid;

  grid-template-columns: repeat(2, minmax(0, 1fr));

  gap: 2rem;

  margin-top: 3rem;
}


.notice-wrapper {

  margin-top: 2rem;

}
</style>
<style is:global>

@media (max-width: 900px) {

  #eligibility-grid {

    grid-template-columns: 1fr;

  }

}
</style>