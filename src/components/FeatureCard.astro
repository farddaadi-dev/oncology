---
import type { IconName } from "@/data/icons";
import { icons } from "@/data/icons";
import { Image } from "astro:assets";

interface Props {
  title: string;
  description: string;
  icon?: IconName;
}

const { title, description, icon } = Astro.props;

const iconSrc = icon ? icons[icon] : undefined;
---

<article class="feature-card">

  {iconSrc && (
    <div class="feature-icon">
      <Image
        src={iconSrc}
        alt=""
      />
    </div>
  )}

  <h3>{title}</h3>

  <p>{description}</p>

</article>

<style>
  .feature-card {
    padding: 2rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    height: 100%;
    background-color: white;
    align-items: center;
    border-radius: var(--radius-lg);
    gap: 1rem;
    border: 1px solid var(--color-brand-green);
    box-shadow: var(--shadow);
    transition:
    transform .25s ease,
    box-shadow .25s ease;
  }

  .feature-card:hover {
    transform: translateY(-6px);

    box-shadow: none;
  }

  .feature-icon {
    width: 72px;
    height: 72px;
    user-select: none;
    border-radius: 18px;

    border: 2px solid var(--color-brand-green-light);

    display: flex;
    align-items: center;
    justify-content: center;

    flex-shrink: 0;
}

.feature-icon :global(img) {
    width: 2.2rem;
    height: 2.2rem;
}

  .feature-card h3 {
    

    font-size: 1.25rem;
    font-weight: 700;

    color: var(--color-text-heading);
  }

  .feature-card p {
    margin: 0;

    line-height: 1.8;

    color: var(--color-text-secondary);
  }
</style>