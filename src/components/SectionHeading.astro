---
interface Props {
  title: string;
  subtitle?: string;
  description?: string;
  align?: "left" | "center" | "right";
}

const {
  title,
  subtitle,
  description,
  align = "center"
} = Astro.props;
---

<header
  class:list={[
    "section-heading",
    `section-heading--${align}`
  ]}
>

  {subtitle && (
    <p class="section-heading__subtitle">
      {subtitle}
    </p>
  )}

  <h2 class="section-heading__title">
    {title}
  </h2>

  {description && (
    <p class="section-heading__description">
      {description}
    </p>
  )}

</header>

<style>
.section-heading {
  max-width: 48rem;

  margin-inline: auto;
  margin-bottom: 3rem;
}

.section-heading--center {
  text-align: center;
}

.section-heading--right {
  text-align: right;
}

.section-heading--left {
  text-align: left;
}

.section-heading__subtitle {
  display: inline-block;

  margin: 0 0 .75rem;
  padding: .35rem 1rem;

  border-radius: 999px;

  background-color: var(--color-brand-green-light);
  color: white;
  padding: 8px 14px;
  font-size: .9rem;
  font-weight: 600;
  line-height: 1;
}

.section-heading__title {
  margin: 0;

  font-size: clamp(2rem, 4vw, 3rem);
  line-height: 1.2;

  color: var(--color-text-primary);
}

.section-heading__description {
  max-width: 42rem;

  margin: 1rem auto 0;

  font-size: 1.05rem;
  line-height: 1.9;

  color: var(--color-text-secondary);
}

.section-heading--left .section-heading__description,
.section-heading--right .section-heading__description {
  margin-inline: 0;
}
</style>