---
import { Image } from "astro:assets";

import { icons } from "@/data/icons";
import type { IconName } from "@/data/icons";

interface Props {
  number: number;
  title: string;
  description?: string;
  icon?: IconName;
}

const {
  number,
  title,
  description,
  icon
} = Astro.props;

const iconImage = icon ? icons[icon] : null;
---

<article class="process-step">

  <div class="process-step__circle">

    {iconImage ? (
      <>
        <Image
          src={iconImage}
          alt=""
          width={32}
          height={32}
          class="process-step__icon"
        />

        <span class="process-step__badge">
          {number}
        </span>
      </>
    ) : (
      <span class="process-step__number">
        {number}
      </span>
    )}

  </div>

  <h3 class="process-step__title">
    {title}
  </h3>

  {description && (
    <p class="process-step__description">
      {description}
    </p>
  )}

</article>

<style>

.process-step {

  display: flex;
  flex-direction: column;
  align-items: center;

  height: 100%;

  max-width: 320px;
  margin-inline: auto;

  padding: 2rem;

  text-align: center;

  background: white;

  border: 1px solid var(--color-border);

  border-radius: var(--radius-lg);

  box-shadow: var(--shadow-normal);

  transition:
    transform .25s ease,
    box-shadow .25s ease;

}

.process-step:hover {

  transform: translateY(-4px);

}

.process-step__circle {

  position: relative;

  display: flex;
  align-items: center;
  justify-content: center;

  width: 4.5rem;
  height: 4.5rem;

  margin-bottom: 1.5rem;

  border-radius: 50%;

  border: 2px solid var(--color-brand-green-light);

  

}

.process-step__icon {

  display: block;

  width: 2rem;
  height: 2rem;

}

.process-step__badge {

  position: absolute;

  top: -6px;
  left: -6px;

  display: flex;
  align-items: center;
  justify-content: center;

  width: 1.5rem;
  height: 1.5rem;

  border-radius: 50%;

  background: white;

  border: 2px solid var(--color-brand-green-light);

  color: var(--color-brand-accent);

  font-size: .75rem;
  font-weight: 700;

}

.process-step__number {

  color: var(--color-brand-accent);

  font-size: var(--text-xl);

  font-weight: 700;

}

.process-step__title {

  margin: 0 0 1rem;

  font-size: var(--text-lg);

  color: var(--color-text-primary);

}

.process-step__description {

  margin: 0;

  line-height: 1.9;

  color: var(--color-text-secondary);

}

</style>