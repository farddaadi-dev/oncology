---
interface Props {
  number: number;
  title: string;
  description?: string;
  icon?: string;
}

const {
  number,
  title,
  description,
  icon
} = Astro.props;
---

<article class="process-step">

  <div class="process-step__circle">

    {icon ? (
      <>
        <img
          src={icon}
          alt=""
          class="process-step__icon"
        />
  
        <span class="process-step__badge">
          {number}
        </span>
      </>
    ) : (
      number
    )}
  
  </div>

  <h3>{title}</h3>

  {description && (
    <p>{description}</p>
  )}

</article>

<style>
  .process-step {
    text-align: center;
    background-color: white;
    padding: 1rem 2rem;
    border-radius: var(--radius-lg);
    box-shadow: 0 4px 4px rgba(0, 0, 0, 0.08);
  }

  .process-step__circle {
  position: relative;

  width: 70px;
  height: 70px;

  margin-inline: auto;
  margin-bottom: 1rem;

  display: flex;
  align-items: center;
  justify-content: center;

  border-radius: 50%;
  border: 1px solid var(--color-brand-accent);

  background: var(--color-bg-warm);

  color: var(--color-brand-accent);
  font-size: var(--text-xl);
}

.process-step__icon {
  width: 32px;
  height: 32px;

  color: white;
}

.process-step__badge {
  position: absolute;

  top: -4px;
  left: -4px;

  width: 24px;
  height: 24px;

  display: flex;
  align-items: center;
  justify-content: center;

  border-radius: 50%;

  color: var(--color-brand-accent);
  background-color: white;
  border: 1px solid var(--color-brand-accent);

  font-size: .75rem;
  font-weight: 700;
}

  .process-step h3 {
    margin: 0 0 0.75rem;
  }

  .process-step p {
    margin: 0;

    line-height: 1.8;

    color: #555;
  }
</style>