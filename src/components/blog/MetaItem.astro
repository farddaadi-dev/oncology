---
interface Props {

    label: string;

    value: string;

    icon?: "author" | "calendar" | "clock" | "update";

}

const {
    label,
    value,
    icon
} = Astro.props;

---

<div
    class="meta-item"
    id="meta-item"
>

    {icon && (

        <div class="meta-item__icon">

            {icon === "author" && (

                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">

                    <circle cx="12" cy="8" r="4"/>

                    <path d="M4 20c1.5-4 5-6 8-6s6.5 2 8 6"/>

                </svg>

            )}

            {icon === "calendar" && (

                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">

                    <rect x="3" y="5" width="18" height="16" rx="2"/>

                    <path d="M8 3v4M16 3v4M3 10h18"/>

                </svg>

            )}

            {icon === "clock" && (

                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">

                    <circle cx="12" cy="12" r="9"/>

                    <path d="M12 7v6l4 2"/>

                </svg>

            )}

            {icon === "update" && (

                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">

                    <path d="M21 12a9 9 0 1 1-3-6.7"/>

                    <polyline points="21 3 21 9 15 9"/>

                </svg>

            )}

        </div>

    )}

    <div class="meta-item__content">

        <span class="meta-item__label">
            {label}
        </span>

        <strong class="meta-item__value">
            {value}
        </strong>

    </div>

</div>


<style>

.meta-item{

    display:flex;

    align-items:center;

    gap:var(--space-md);

}

.meta-item__icon{

    width:42px;

    height:42px;

    flex-shrink:0;

    display:flex;

    align-items:center;

    justify-content:center;

    border-radius:50%;

    background:var(--color-bg-section);

    color:var(--color-brand-green);

}

.meta-item__icon svg{

    width:22px;

    height:22px;

}

.meta-item__content{

    display:flex;

    flex-direction:column;

    gap:.2rem;

}

.meta-item__label{

    font-size:var(--text-sm);

    color:var(--color-text-secondary);

}

.meta-item__value{

    font-size:var(--text-base);

    color:var(--color-text-primary);

   white-space: nowrap; 

}


</style>


<style is:global>

@media(max-width:640px){

#meta-item{

    align-items:flex-start;

}

#meta-item .meta-item__icon{

    width:36px;

    height:36px;

}

#meta-item .meta-item__value{

    white-space:normal;

}

}

</style>