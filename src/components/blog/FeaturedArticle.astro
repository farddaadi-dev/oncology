---
import type { CollectionEntry } from "astro:content";
import ReadArticleLink from "./ReadArticleLink.astro";
import { formatDate } from "@/lib/formatDate";
import { getReadingTime } from "@/lib/getReadingTime";
import { getCategoryLabel } from "@/data/categories";

interface Props {
    post: CollectionEntry<"blog">;
}

const { post } = Astro.props;

const {
    title,
    excerpt,
    image,
    imageAlt,
    category,
    publishDate,
} = post.data;

import { getPostUrl } from "@/lib/getPostUrl";

const href = getPostUrl(post);

const readingTime = getReadingTime(post.body);

const formattedDate = formatDate(publishDate);
---

<article class="featured-article" id="featured-article">

<a
    href={href}
    aria-label={title}
    class="featured-article__image"
>

    <img
        src={image}
        alt={imageAlt}
        loading="eager"
    />

</a>

<div class="featured-article__content">

    <span class="featured-article__category">

        {getCategoryLabel(category)}

    </span>

    <h2 class="featured-article__title">

        <a href={href}>

            {title}

        </a>

    </h2>

    <p class="featured-article__description">

        {excerpt}

    </p>

    <div class="featured-article__footer">

        <time datetime={publishDate.toISOString()}>
            {formattedDate}
        </time>

        <span
            class="featured-article__separator"
            aria-hidden="true"
        >

        •

        </span>

        <span>

            {readingTime}

        </span>

        <ReadArticleLink href={href} />

    </div>

</div>

</article>

<style>

.featured-article{

display:grid;

grid-template-columns:1.1fr 1fr;

gap:var(--space-2xl);

align-items:center;

padding:var(--space-xl);

background:var(--color-bg-primary);

border:1px solid var(--color-border);

border-radius:var(--radius-xl);

box-shadow:var(--shadow-soft);

}

.featured-article__image{

display:block;

overflow:hidden;

border-radius:var(--radius-lg);

}

.featured-article__image img{

width:100%;

aspect-ratio:16/9;

object-fit:cover;

display:block;

border:1px solid var(--color-border);

transition:transform .4s ease;

}

.featured-article:hover img{

transform:scale(1.03);

}

.featured-article__category{

display:inline-block;

padding:.4rem 1rem;

margin-bottom:var(--space-md);

background:var(--color-bg-section);

color:var(--color-brand-green-dark);

border-radius:999px;

font-size:var(--text-sm);

font-weight:600;

user-select:none;

}

.featured-article__title{

margin-bottom:var(--space-md);

}

.featured-article__title a{

text-decoration:none;

color:inherit;

}

.featured-article__title a:hover{

color:var(--color-brand-green);

}

.featured-article__description{

color:var(--color-text-secondary);

margin-bottom:var(--space-xl);

}

.featured-article__footer{

display:flex;

flex-wrap:wrap;

gap:var(--space-lg);

align-items:center;

color:var(--color-text-secondary);

font-size:var(--text-sm);

justify-content:space-between;

}



.featured-article__separator{

    opacity:.5;

}

.featured-article__title a:focus-visible,
.featured-article__image:focus-visible
{

    outline:3px solid var(--color-brand-accent);

    outline-offset:4px;

}

</style>

<style is:global>

@media(max-width:900px){

#featured-article{

    grid-template-columns:1fr;

}

}

</style>