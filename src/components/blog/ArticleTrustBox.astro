---
import { authors, type AuthorId } from "../../data/authors";
import { formatDate } from "@/lib/formatDate";

interface Props {

    author: AuthorId;

    reviewedDate?: Date;

    sources?: string[];

}

const {

    author,

    reviewedDate,

    sources = []

} = Astro.props;


const authorInfo = authors[author];

---

<section class="trust-box" id="trust-box">

    <h2>
        اعتبار و منابع علمی مقاله
    </h2>


    <p class="trust-box__intro">
        این مقاله توسط پزشکان متخصص هماتولوژی و انکولوژی تهیه شده و بر اساس منابع معتبر علمی به‌روز شده است.
    </p>


    <ul class="trust-box__list">


        <li>

            <span class="icon">
                ✓
            </span>

            <div class="trust-box__item-text">

                <strong>
                    نویسنده مقاله
                </strong>

                <br>

                {authorInfo.name}

                <br>

                {authorInfo.title}

            </div>

        </li>



        {reviewedDate && (

            <li>

                <span class="icon">
                    ✓
                </span>


                <div class="trust-box__item-text">

                    <strong>
                        آخرین بازبینی علمی
                    </strong>


                    <br>

                    {formatDate(reviewedDate)}

                </div>


            </li>

        )}



        {sources.length > 0 && (

            <li>

                <span class="icon">
                    ✓
                </span>


                <div class="trust-box__item-text">

                    <strong>
                        منابع علمی و راهنماهای مورد استفاده
                    </strong>


                    <div class="sources">


                        {
                            sources.map(source => (

                                <span class="source-pill">

                                    {source}

                                </span>

                            ))
                        }


                    </div>


                </div>

            </li>

        )}



    </ul>


</section>



<style>

.trust-box{

    margin-block:var(--space-3xl);

    padding:var(--space-2xl);

    background:var(--color-bg-section);

    border:1px solid var(--color-border);

    border-radius:var(--radius-xl);
    

}


.trust-box h2{

    margin-top:0;

    margin-bottom:var(--space-md);

}


.trust-box__intro{

    color:var(--color-text-secondary);

    line-height:1.9;

    margin-bottom:var(--space-xl);

}



.trust-box__list{

    list-style:none;

    padding:0;

    margin:0;

    display:grid;

    gap:var(--space-lg);

}



.trust-box__list li{

    display:flex;

    gap:var(--space-md);

    align-items:flex-start;

}



.trust-box__item-text{

    flex:1;

    line-height:1.8;

}



.icon{

    width:32px;

    height:32px;

    flex-shrink:0;

    display:flex;

    align-items:center;

    justify-content:center;

    border-radius:50%;

    background:var(--color-brand-green);

    color:white;

    font-weight:bold;

}



.sources{

    display:flex;

    flex-wrap:wrap;

    gap:var(--space-sm);

    margin-top:var(--space-sm);

}



.source-pill{

    background:var(--color-bg-primary);

    border:1px solid var(--color-border);

    border-radius:999px;

    padding:.35rem .8rem;

    font-size:var(--text-sm);

}



</style>



<style is:global>

@media(max-width:640px){

#trust-box{

    padding:var(--space-lg);

}


#trust-box .trust-box__list li{

    gap:var(--space-sm);

}


#trust-box .trust-box__item-text{

    font-size:var(--text-sm);

}


}

</style>