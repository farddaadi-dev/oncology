---
import type { CollectionEntry } from "astro:content";
import ReadArticleLink from "./ReadArticleLink.astro";
import { formatDate } from "@/lib/formatDate";
import { getReadingTime } from "@/lib/getReadingTime";
import { getCategoryLabel } from "@/data/categories";

interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;

const {
  title,
  excerpt,
  category,
  image,
  imageAlt,
  publishDate,
} = post.data;

import { getPostUrl } from "@/lib/getPostUrl";

const href = getPostUrl(post);

const readingTime = getReadingTime(post.body);
---

<article
  class="blog-card"
  data-search={`
    ${title}
    ${excerpt}
    ${category}
    ${post.data.tags.join(" ")}
  `.toLowerCase()}
>

  {
    image && (
      <a href={href} class="blog-card__image-link">
        <img
          src={image}
          alt={imageAlt ?? title}
          class="blog-card__image"
          loading="lazy"
          decoding="async"
        />
      </a>
    )
  }

  <div class="blog-card__content">

      <span class="blog-card__category">
        {getCategoryLabel(category)}
      </span>

      <h3 class="blog-card__title">
        {title}
      </h3>

      <p class="blog-card__description">
        {excerpt}
      </p>

      <div class="blog-card__meta">

        <time datetime={publishDate.toISOString()}>
          {formatDate(publishDate)}
        </time>

        <span class="blog-card__separator" aria-hidden="true">
          •
        </span>

        <span>
          {readingTime}
        </span>
        <ReadArticleLink href={href} />
        </div>
          
  </div>

  

</article>

<style>

.blog-card{

display:flex;

flex-direction:column;

height:100%;

border:1px solid var(--color-border);

border-radius:var(--radius-lg);

overflow:hidden;

background:var(--color-bg-primary);

box-shadow:var(--shadow-soft);

transition:
    transform var(--transition-normal),
    box-shadow var(--transition-normal);

}

.blog-card:hover{

    transform:translateY(-4px);

    box-shadow:var(--shadow-medium);

}

.blog-card:hover .blog-card__image{

    transform:scale(1.03);

}

.blog-card__image-link{
    display:block;
    overflow:hidden;
}






.blog-card__image{

    width:100%;

    aspect-ratio:16/9;

    object-fit:cover;

    display:block;

    border-bottom:1px solid var(--color-border);

    transition:transform var(--transition-normal);

}

.blog-card__content{

    display:flex;

    flex-direction:column;

    flex:1;

    padding:var(--space-lg);

    align-items:flex-start;

}

.blog-card__category{

    align-self:flex-start;

    margin-bottom:var(--space-sm);

    padding:.3rem .75rem;

    border-radius:999px;

    background:var(--color-bg-section);

    color:var(--color-brand-green);

    font-size:var(--text-sm);

    font-weight:600;

    user-select:none;

}

.blog-card__title{

    margin:0 0 var(--space-md);

    color:var(--color-dark-heading);

}

.blog-card__description{

    flex:1;

    margin-bottom:var(--space-lg);

    color:var(--color-text-secondary);

}

.blog-card__meta{

    display:flex;

    flex-wrap:wrap;

    align-items:center;

    gap:var(--space-lg);

    font-size:var(--text-sm);

    color:var(--color-text-secondary);

    justify-content:space-between;

}

.blog-card__separator{

    opacity:.5;

}

</style>

<style is:global>

@media(max-width:768px){

    .blog-card .blog-card__content{

        padding:var(--space-md);

    }

}

</style>