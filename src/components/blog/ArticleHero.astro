---
import type { CollectionEntry } from "astro:content";

import MetaItem from "./MetaItem.astro";

import { authors } from "@/data/authors";
import { getCategoryLabel } from "@/data/categories";
import { formatDate } from "@/lib/formatDate";
import { getReadingTime } from "@/lib/getReadingTime";


interface Props {

    post: CollectionEntry<"blog">;

}


const { post } = Astro.props;


const {
    title,
    description,
    category,
    author,
    publishDate,
    updatedDate,
} = post.data;


const authorInfo = authors[author];

const readingTime = getReadingTime(post.body ?? "");


---

<section
    class="article-hero"
    id="article-hero"
>

    <div class="article-hero__category">

        {getCategoryLabel(category)}

    </div>


    <h1 class="article-hero__title">

        {title}

    </h1>


    <p class="article-hero__description">

        {description}

    </p>


    <div class="article-hero__meta">

        <MetaItem
            icon="author"
            label="نویسنده"
            value={authorInfo.name}
        />


        <MetaItem
            icon="calendar"
            label="تاریخ انتشار"
            value={formatDate(publishDate)}
        />


        <MetaItem
            icon="clock"
            label="زمان مطالعه"
            value={readingTime}
        />


        {
            updatedDate && (

                <MetaItem
                    icon="update"
                    label="آخرین بروزرسانی"
                    value={formatDate(updatedDate)}
                />

            )
        }


    </div>


</section>



<style>

.article-hero{

    margin-bottom:var(--space-3xl);

}


.article-hero__category{

    display:inline-flex;

    align-items:center;

    padding:.4rem 1rem;

    margin-bottom:var(--space-lg);

    border-radius:var(--radius-full);

    background:var(--color-bg-section);

    color:var(--color-brand-green);

    font-size:var(--text-sm);

    font-weight:600;

}


.article-hero__title{

    margin:0;

    max-width:900px;

    font-family:var(--font-estedad);

    font-size:clamp(2rem,4vw,3.2rem);

    line-height:1.5;

    color:var(--color-dark-heading);

}


.article-hero__description{

    max-width:850px;

    margin-top:var(--space-lg);

    margin-bottom:var(--space-2xl);

    font-size:var(--text-lg);

    line-height:2;

    color:var(--color-text-secondary);

}


.article-hero__meta{

    display:grid;

    grid-template-columns:repeat(4,1fr);

    /* grid-template-columns:repeat(auto-fit,minmax(220px,1fr)); */

    gap:var(--space-xl);

    padding-block:var(--space-xl);

    border-block:

        1px solid var(--color-border);

}


</style>



<style is:global>

@media(max-width:900px){

#article-hero .article-hero__meta{

    grid-template-columns:repeat(2,1fr);

}

}


@media(max-width:640px){

#article-hero .article-hero__meta{

    grid-template-columns:1fr;

    gap:var(--space-lg);

}


#article-hero .article-hero__title{

    font-size:2rem;

}


#article-hero .article-hero__description{

    font-size:var(--text-base);

}

}

</style>