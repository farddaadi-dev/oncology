---
interface Props {
  title?: string;
  showContactLink?: boolean;
}

const {
  title = "نکات مهم درباره این مطلب",
  showContactLink = true
} = Astro.props;
---

<aside class="article-disclaimer" id="article-disclaimer">
    <div class="article-disclaimer__icon">

        <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            aria-hidden="true"
        >
            <circle cx="12" cy="12" r="10" />
            <line x1="12" y1="8" x2="12" y2="12" />
            <circle cx="12" cy="16" r="1" fill="currentColor" stroke="none" />
        </svg>

    </div>

    <div class="article-disclaimer__content">

        <h2 class="article-disclaimer__title">
            {title}
        </h2>

        <p>
            مطالب منتشرشده در این وب‌سایت با هدف افزایش آگاهی بیماران و کمک به درک بهتر بیماری‌ها و روش‌های درمان تهیه شده‌اند و جایگزین ویزیت، تشخیص یا توصیه اختصاصی پزشک نیستند.             
        </p>

        <p>
            شرایط هر بیمار منحصر‌به‌فرد است و تصمیم‌گیری درباره تشخیص، آزمایش‌ها و روش درمان باید بر اساس نظر پزشک متخصص و شرایط بالینی هر فرد انجام شود.
        </p>

        {showContactLink && (

            <p class="article-disclaimer__contact">

                در صورت نیاز به مشاوره تخصصی، می‌توانید از طریق 
                <a href="/contact">
                    صفحه تماس با ما
                </a>
                یا
                <a href="/visit">
                    صفحه ویزیت
                </a>
                با ما در ارتباط باشید.

            </p>

        )}

    </div>

</aside>

<style>

.article-disclaimer{

    display:grid;

    grid-template-columns:auto 1fr;

    gap:var(--space-lg);

    padding:var(--space-xl);

    margin-block:var(--space-3xl);

    border:1px solid var(--color-border);

    border-radius:var(--radius-xl);

    background:var(--color-bg-section);

}

.article-disclaimer__icon{

    width:56px;
    height:56px;

    display:flex;
    align-items:center;
    justify-content:center;

    border-radius:50%;

    background:var(--color-bg-primary);

    color:var(--color-brand-accent);

    flex-shrink:0;

}

.article-disclaimer__icon svg{

    width:28px;
    height:28px;

}

.article-disclaimer__title{

    margin:0 0 var(--space-md);

}

.article-disclaimer__content p{

    margin-bottom:var(--space-md);

    color:var(--color-text-secondary);

}

.article-disclaimer__content p:last-child{

    margin-bottom:0;

}

.article-disclaimer__contact a{

    color:var(--color-brand-green);

    text-decoration:none;

    font-weight:600;

    margin-inline:.25rem;

}

.article-disclaimer__contact a:hover{

    text-decoration:underline;

}

.article-disclaimer__contact a:focus-visible{

    outline:3px solid var(--color-brand-accent);

    outline-offset:3px;

    border-radius:4px;

}

</style>

<style is:global>

@media (max-width: 768px){

    #article-disclaimer{

        grid-template-columns:1fr;

        text-align:center;

        padding:var(--space-lg);

    }

    .article-disclaimer .article-disclaimer__icon{

        margin-inline:auto;

    }

}

</style>