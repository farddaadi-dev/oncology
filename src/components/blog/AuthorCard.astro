---
import { authors } from "@/data/authors";
import { Image } from "astro:assets";

type AuthorId = keyof typeof authors;

interface Props {
    author: AuthorId;
}

const { author } = Astro.props;

const info = authors[author];

if (!info) {
  throw new Error(`Unknown author: ${author}`);
}
---

<section class="author-card" id="author-card">

    <Image
    src={info.image}
    alt={info.name}
    class="author-card__image"
    loading="lazy"
/>

    <div class="author-card__content">

        <span class="author-card__label">
            نویسنده مقاله
        </span>

        <h2>{info.name}</h2>

        <p class="author-card__title">
            {info.title}
        </p>

        <p>
            {info.bio}
        </p>

        {info.credentials.length > 0 && (

            <ul class="author-card__credentials">
            
                {info.credentials.map((item) => (
            
                    <li>{item}</li>
            
                ))}
            
            </ul>
            
            )}

        {info.profileUrl && (
            <a
            href={info.profileUrl}
            class="author-card__link"
            >
            مشاهده صفحه معرفی پزشک
            </a>
            )}

    </div>

</section>

<style>
    .author-card {
    
        display: flex;
    
        gap: 1.5rem;
    
        padding: 2rem;
    
        background: var(--color-bg-secondary);
    
        border: 1px solid var(--color-border);
    
        border-radius: var(--radius-lg);
    
        box-shadow: var(--shadow-normal);
    
        align-items: flex-start;
    }
    
    
    /* Author image */
    
    .author-card__image {
    
        width: 120px;
    
        height: 150px;
    
        flex-shrink: 0;
    
        border-radius: 50%;
    
        object-fit: cover;
    
        object-position: center top;
    }
    
    
    /* Content */
    
    .author-card__content {
    
        flex: 1;
    
    }
    
    
    .author-card__label {
    
        display: inline-block;
    
        margin-bottom: .5rem;
    
        font-size: .9rem;
    
        color: var(--color-brand-accent);
    
        font-weight: 600;
    }
    
    
    .author-card h2 {
    
        margin: 0 0 .5rem;
    
        font-size: 1.25rem;
    
        color: var(--color-text-heading);
    
    }
    
    
    .author-card__title {
    
        margin: 0 0 1rem;
    
        color: var(--color-brand-green);
    
        font-weight: 600;
    
    }
    
    
    .author-card p {
    
        line-height: 1.9;
    
        color: var(--color-text-secondary);
    
        margin-bottom: 1rem;
    
    }
    
    
    /* Credentials */
    
    .author-card__credentials {
    
        list-style: none;
    
        padding: 0;
    
        margin: 1rem 0;
    
    }
    
    
    .author-card__credentials li {
    
        position: relative;
    
        padding-right: 1.25rem;
    
        margin-bottom: .5rem;
    
        color: var(--color-text-primary);
    
    }
    
    
    .author-card__credentials li::before {
    
        content: "✓";
    
        position: absolute;
    
        right: 0;
    
        color: var(--color-brand-accent);
    
        font-weight: bold;
    
    }
    
    
    /* Link */
    
    .author-card__link {
    
        display: inline-block;
    
        margin-top: .5rem;
    
        color: var(--color-brand-accent);
    
        font-weight: 600;
    
        text-decoration: none;
    
    }
    
    
    .author-card__link:hover {
    
        text-decoration: underline;
    
    }
    
    
    /* Mobile */
    
    @media (max-width: 600px) {
    
        #author-card {
    
            flex-direction: column;
    
            align-items: center;
    
            text-align: center;
    
            padding: 1.5rem;
    
        }
    
    
        .author-card__image {
    
            width: 64px;
    
            height: 80px;
    
        }
    
    
        .author-card__credentials {
    
            text-align: right;
    
        }
    
    }
    </style>