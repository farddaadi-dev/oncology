---
import ButtonLink from "./ButtonLink.astro";

interface Props {
  title: string;
  description?: string;
  buttonText: string;
  buttonHref: string;
}

const {
  title,
  description,
  buttonText,
  buttonHref
} = Astro.props;
---

<section class="cta">

  <div class="cta-content">

    <h2>{title}</h2>

    {description && (
      <p>{description}</p>
    )}

    <ButtonLink href={buttonHref}>
      {buttonText}
    </ButtonLink>

  </div>

</section>

<style>
  .cta {
    padding: 4rem 2rem;

    border-radius: 1.5rem;

    text-align: center;

    background: var(--color-primary);

    color: white;
  }

  .cta-content {
    max-width: 700px;
    margin-inline: auto;
  }

  .cta h2 {
    margin: 0 0 1rem;

    font-size: clamp(1.8rem, 4vw, 2.5rem);
  }

  .cta p {
    margin: 0 0 2rem;

    line-height: 1.8;

    opacity: 0.9;
  }
</style>