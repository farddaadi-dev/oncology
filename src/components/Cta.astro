---
import Section from "@/components/Section.astro";

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description
} = Astro.props;
---

<Section>

  <div
    class="cta-content"
    id="cta-content"
  >

    <h2 class="cta-title">
      {title}
    </h2>

    {description && (
      <p class="cta-description">
        {description}
      </p>
    )}

    <div
      class="cta-actions"
      id="cta-actions"
    >
      <slot />
    </div>

  </div>

</Section>

<style>

.cta-content {

  max-width: 760px;

  margin-inline: auto;

  padding: 3rem;

  text-align: center;

  background: var(--color-bg-hero);

  border: 1px solid var(--color-border);

  border-radius: var(--radius-xl);

  box-shadow: var(--shadow);

}

.cta-title {

  margin: 0 0 1.25rem;

  color: var(--color-text-heading);

  font-size: clamp(2rem, 4vw, 2.75rem);

  line-height: 1.3;

}

.cta-description {

  max-width: 42rem;

  margin: 0 auto;

  color: var(--color-text-secondary);

  line-height: 2;
  fonnt-size: var(--text-lead);

}

.cta-actions {

  display: flex;

  justify-content: center;

  align-items: center;

  flex-wrap: wrap;

  gap: 1rem;

  margin-top: 2.5rem;

}

</style>

<style is:global>

@media (max-width: 768px) {

  #cta-content {

    padding: 2.25rem 1.5rem;

  }

  #cta-actions {

    flex-direction: column;

    align-items: center;

  }

}

</style>