---
import ButtonLink from './ButtonLink.astro';
import type { IconName } from "@/data/icons";
import { icons } from "@/data/icons";
import { Image } from "astro:assets";

interface Props {
  title: string;
  description: string;
  href: string;
  icon?: IconName;
}

const { title, description, href, icon } = Astro.props;
const iconSrc = icon ? icons[icon] : undefined;
---

<article class="service-card">

  {iconSrc && (
    <div class="service-icon">
      <Image
        src={iconSrc}
        alt=""
      />
    </div>
  )}

  <h3>{title}</h3>

  <p>{description}</p>

  <ButtonLink 
    href={href}
    text="مشاهده جزئیات"
    
  />

</article>

<style>
  .service-card {
    background: white;
    border-radius: var(--radius-lg);
    padding: 2rem;
    box-shadow: var(--shadow-normal);
    border: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
    gap: 1rem;
    position: relative;
    overflow: hidden;
    transition:
    transform .25s ease,
    box-shadow .25s ease;

    height: 100%;
  }

  .service-card::before {
    content: "";

    position: absolute;
    inset-inline: 0;
    top: 0;

    height: 4px;

    background: linear-gradient(
        90deg,
        var(--color-brand-green),
        var(--color-brand-accent)
    );
}

  /* .service-card:hover {
    transform: translateY(-6px);

    box-shadow: var(--shadow-medium);
  } */

  .service-icon {
    width: 72px;
    height: 72px;

    display: flex;
    align-items: center;
    justify-content: center;

    border-radius: 18px;
    border: 2px solid var(--color-brand-green-light);

    flex-shrink: 0;
}

.service-icon :global(img) {
    width: 2.5rem;
    height: 2.5rem;
}

  .service-card h3 {
    margin: 0;

    font-size: 1.4rem;
    font-weight: 700;

    color: var(--color-text-heading);
  }

  .service-card p {
    margin: 0;

    color: var(--color-text-secondary);
    line-height: 1.8;

    flex-grow: 1;
  }

  .service-card :global(.button) {
    margin-top: 1rem;
    align-self: flex-start;
}
</style>