---
interface Props {
  items: string[];
  icon: string;
}

const {
  items,
  icon
} = Astro.props;
---

<ul class="checklist">

  {items.map(item => (
    <li class="checklist__item">

      <img
        src={icon}
        alt=""
        aria-hidden="true"
        class="checklist__icon"
      />

      <span>
        {item}
      </span>

    </li>
  ))}

</ul>

<style>
.checklist {
  list-style: none;

  margin: 0;
  padding: 0;
}

.checklist__item {
  display: flex;
  align-items: flex-start;
  gap: .75rem;

  padding: .85rem 0;

  border-bottom: 1px solid var(--color-border);
}

.checklist__item:last-child {
  border-bottom: none;
}

.checklist__icon {
  display: block;

  width: 1.25rem;
  height: 1.25rem;

  flex-shrink: 0;

  margin-top: .25rem;
}
</style>