---
import { Image } from "astro:assets";

import { icons } from "@/data/icons";
import type { IconName } from "@/data/icons";

interface Props {
  items: string[];
  icon: IconName;
}

const {
  items,
  icon
} = Astro.props;

const iconImage = icons[icon];
---

<ul class="checklist">

  {items.map(item => (
    <li class="checklist__item">

      <Image
        src={iconImage}
        alt=""
        aria-hidden="true"
        width={20}
        height={20}
        class="checklist__icon"
      />

      <span>
        {item}
      </span>

    </li>
  ))}

</ul>

<style>
.checklist {
  list-style: none;

  margin: 0;
  padding: 0;
}

.checklist__item {
  display: flex;
  align-items: flex-start;
  gap: .75rem;

  padding: .85rem 0;

  border-bottom: 1px solid var(--color-border);
}

.checklist__item:last-child {
  border-bottom: none;
}

.checklist__icon {
  display: block;

  flex-shrink: 0;

  margin-top: .25rem;
}
</style>