---
import "../styles/global.css";

import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title: string;
  description: string;
  image?: string;

  canonical?: string;
  noindex?: boolean;
  type?: "website" | "article";
}

const {
  title,
  description,
  image,
  canonical,
  noindex = false,
  type = "website",
} = Astro.props;
---

<!DOCTYPE html>
<html lang="fa-IR" dir="rtl">
  <head>
    <BaseHead
      title={title}
      description={description}
      image={image}
      canonical={canonical}
      noindex={noindex}
      type={type}
    />
  </head>

  <body>
    <Header />

    <main>
      <slot />
    </main>

    <Footer />
  </body>
</html>